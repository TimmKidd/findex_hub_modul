def _extract_profile_from_respond(respond: Respond) -> dict | None:
    """
    Пытаемся восстановить профиль максимально бережно:
    1. canonical: structured["candidate_profile"]
    2. legacy flat keys в structured
    3. альтернативные старые ключи
    """
    structured = getattr(respond, "structured", None)
    if not isinstance(structured, dict):
        return None

    p = structured.get("candidate_profile")
    if isinstance(p, dict):
        normalized = {
            "name": str(p.get("name") or "").strip(),
            "age": str(p.get("age") or "").strip(),
            "citizenship": str(p.get("citizenship") or "").strip(),
            "experience": str(p.get("experience") or "").strip(),
            "resume_link": str(p.get("resume_link") or "").strip(),
            "resume_file_id": p.get("resume_file_id"),
            "resume_file_name": str(p.get("resume_file_name") or "").strip(),
        }
        if any(
            [
                normalized["name"],
                normalized["age"],
                normalized["citizenship"],
                normalized["experience"],
                normalized["resume_link"],
                normalized["resume_file_id"],
                normalized["resume_file_name"],
            ]
        ):
            return normalized

    legacy = {
        "name": str(
            structured.get("form_name")
            or structured.get("candidate_name")
            or structured.get("name")
            or ""
        ).strip(),
        "age": str(
            structured.get("form_age")
            or structured.get("candidate_age")
            or structured.get("age")
            or ""
        ).strip(),
        "citizenship": str(
            structured.get("form_citizenship")
            or structured.get("candidate_citizenship")
            or structured.get("citizenship")
            or ""
        ).strip(),
        "experience": str(
            structured.get("form_experience")
            or structured.get("candidate_experience")
            or structured.get("experience")
            or ""
        ).strip(),
        "resume_link": str(
            structured.get("resume_link")
            or structured.get("candidate_resume_link")
            or ""
        ).strip(),
        "resume_file_id": structured.get("resume_file_id") or structured.get("candidate_resume_file_id"),
        "resume_file_name": str(
            structured.get("resume_file_name")
            or structured.get("candidate_resume_file_name")
            or ""
        ).strip(),
    }

    if any(
        [
            legacy["name"],
            legacy["age"],
            legacy["citizenship"],
            legacy["experience"],
            legacy["resume_link"],
            legacy["resume_file_id"],
            legacy["resume_file_name"],
        ]
    ):
        return legacy

    return None


def _build_card_text(ad: Ad, respond: Respond, view: str) -> str:
    url = _channel_post_url_from_ad(ad)
    link_line = f'Ссылка: <a href="{url}">Открыть</a>' if url else "Ссылка: —"

    cand_id = int(getattr(respond, "candidate_user_id", 0) or 0)

    peer_line = ""
    if view == "author":
        nick = _candidate_nick_from_respond(respond)
        if nick:
            nick = nick.lstrip("@")
            peer_line = f"Кандидат: @{nick}"
        else:
            peer_line = f"Кандидат: <code>{cand_id}</code>"

    prof = _extract_profile_from_respond(respond)

    structured = getattr(respond, "structured", None)
    structured = structured if isinstance(structured, dict) else {}
    thread_txt = _render_thread(structured)

    status_txt = _status_text(respond, view=view)

    parts: list[str] = [
        "📩 <b>Отклик на вакансию</b>",
        f"Отклик: <code>#{int(respond.id)}</code>",
        f"Объявление: <code>#{int(ad.id)}</code>",
        f"{link_line}",
    ]

    if peer_line:
        parts.append(peer_line)

    parts.append(f"Статус: {status_txt}")
    parts.append("")

    if prof:
        parts.append("🧑‍💼 <b>Анкета кандидата</b>")
        parts.extend(_render_profile_lines(prof))
        parts.append("")
    else:
        parts.append("🧑‍💼 <b>Анкета кандидата</b>")
        parts.append("⚠️ Данные анкеты временно недоступны")
        parts.append("")

    parts.append("🧵 <b>Переписка</b>")
    parts.append(thread_txt)

    try:
        thread_items = structured.get("thread") if isinstance(structured, dict) else []
        thread_count = len(thread_items) if isinstance(thread_items, list) else 0
    except Exception:
        thread_count = 0

    current_status = _norm_status(getattr(respond, "status", None))

    if current_status == ST_NEW and thread_count <= 1:
        parts.append("")
        parts.append("⚡ Диалог начинается сразу после отклика")

    return _shorten("\n".join(parts))


def _kb_for(
    respond: Respond,
    view: str,
    *,
    browse_mode: bool = False,
    side: str | None = None,
    bucket: str | None = None,
    page: int | None = None,
) -> InlineKeyboardMarkup:
    status = _norm_status(getattr(respond, "status", None))
    structured = getattr(respond, "structured", None)
    collapsed = _get_collapsed(structured, view)

    if view == "author":
        return author_card_kb(
            int(respond.id),
            collapsed=collapsed,
            status=status,
            browse_mode=browse_mode,
            side=side,
            bucket=bucket,
            page=page,
        )

    return candidate_card_kb(
        int(respond.id),
        collapsed=collapsed,
        status=status,
        browse_mode=browse_mode,
        side=side,
        bucket=bucket,
        page=page,
    )


def _text_for(ad: Ad, respond: Respond, view: str) -> str:
    structured = getattr(respond, "structured", None)
    collapsed = _get_collapsed(structured, view)
    if collapsed:
        return _build_compact_text(ad, respond)
    return _build_card_text(ad, respond, view=view)


async def _upsert_card_for_view(bot, session, respond: Respond, ad: Ad, *, view: str) -> bool:
    text = _text_for(ad, respond, view=view)
    kb = _kb_for(respond, view=view)

    if view == "author":
        chat_id = int(getattr(respond, "author_chat_id", 0) or getattr(respond, "author_user_id", 0) or 0)
        msg_id = getattr(respond, "author_message_id", None)
    else:
        chat_id = int(getattr(respond, "candidate_chat_id", 0) or getattr(respond, "candidate_user_id", 0) or 0)
        msg_id = getattr(respond, "candidate_message_id", None)

    if not chat_id:
        logger.warning("_upsert_card_for_view: no chat_id respond_id=%s view=%s", getattr(respond, "id", None), view)
        return False

    if msg_id:
        try:
            await bot.edit_message_text(
                chat_id=chat_id,
                message_id=int(msg_id),
                text=text,
                parse_mode=ParseMode.HTML,
                reply_markup=kb,
                link_preview_options=LinkPreviewOptions(is_disabled=True),
            )
            return True
        except Exception as e:
            if "message is not modified" in str(e).lower():
                return True
            logger.warning(
                "_upsert_card_for_view: edit failed -> resend respond_id=%s view=%s chat_id=%s msg_id=%s err=%r",
                getattr(respond, "id", None),
                view,
                chat_id,
                msg_id,
                e,
            )

    try:
        m = await bot.send_message(
            chat_id=chat_id,
            text=text,
            parse_mode=ParseMode.HTML,
            reply_markup=kb,
            link_preview_options=LinkPreviewOptions(is_disabled=True),
        )
    except Exception:
        logger.exception(
            "_upsert_card_for_view: send failed respond_id=%s view=%s chat_id=%s",
            getattr(respond, "id", None),
            view,
            chat_id,
        )
        return False

    if view == "author":
        respond.author_chat_id = int(chat_id)  # type: ignore
        respond.author_message_id = int(m.message_id)  # type: ignore
    else:
        respond.candidate_chat_id = int(chat_id)  # type: ignore
        respond.candidate_message_id = int(m.message_id)  # type: ignore

    return True


async def _sync_cards(bot, session, respond: Respond, ad: Ad) -> None:
    changed = False

    ok_author = await _upsert_card_for_view(bot, session, respond, ad, view="author")
    ok_candidate = await _upsert_card_for_view(bot, session, respond, ad, view="candidate")

    changed = ok_author or ok_candidate

    if changed:
        await session.commit()


@router.callback_query(F.data.startswith(f"{CB_TOGGLE}:"))
async def toggle_card(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    parts = (cb.data or "").split(":")
    if len(parts) not in (2, 5):
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    try:
        respond_id = int(parts[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    browse_mode = False
    side: str | None = None
    bucket: str | None = None
    page: int | None = None

    if len(parts) == 5:
        try:
            side = parts[2].strip()
            bucket = parts[3].strip()
            page = int(parts[4])
            browse_mode = True
        except Exception:
            return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

        if side not in {"candidate", "author"} or bucket not in {"active", "closed"}:
            return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        repo = RespondRepo(session)

        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        uid = int(cb.from_user.id)
        if uid == int(getattr(r, "author_user_id", 0) or 0):
            view = "author"
            try:
                fn = getattr(repo, "mark_owner_viewed_if_null", None)
                if callable(fn):
                    await fn(int(respond_id))
                r = await session.get(Respond, int(respond_id)) or r
            except Exception:
                logger.exception("toggle_card: mark_owner_viewed_if_null failed respond_id=%s", respond_id)
        elif uid == int(getattr(r, "candidate_user_id", 0) or 0):
            view = "candidate"
        else:
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

        ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
        if not ad:
            return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

        structured0 = _ensure_structured(getattr(r, "structured", None))
        cur = _get_collapsed(structured0, view)

        collapsed_new = dict(structured0["collapsed"])
        collapsed_new[view] = (not cur)

        structured_new = dict(structured0)
        structured_new["collapsed"] = collapsed_new

        r.structured = structured_new  # type: ignore

        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        await session.commit()

        r_fresh: Respond | None = await session.get(Respond, int(respond_id))
        if not r_fresh:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        text = _text_for(ad, r_fresh, view=view)
        kb = _kb_for(
            r_fresh,
            view=view,
            browse_mode=browse_mode,
            side=side,
            bucket=bucket,
            page=page,
        )

    try:
        await _set_active_respond(redis, int(cb.from_user.id), int(respond_id))
    except Exception:
        logger.exception("toggle_card: failed to set active respond user_id=%s respond_id=%s", cb.from_user.id, respond_id)

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=kb,
        parse_mode=ParseMode.HTML,
    )


async def _guard_ad_for_respond(cb_or_msg: Any, ad_id: int) -> Optional[Ad]:
    async with get_sessionmaker()() as session:
        repo = AdRepo(session)
        ad = await repo.get(ad_id)

    if not ad:
        if isinstance(cb_or_msg, CallbackQuery):
            await safe_answer(cb_or_msg, "❌ Объявление не найдено", alert=True)
        else:
            await cb_or_msg.answer("❌ Объявление не найдено")
        return None

    payload = getattr(ad, "payload", None) or {}

    if getattr(ad, "status", None) != "published":
        if isinstance(cb_or_msg, CallbackQuery):
            await safe_answer(cb_or_msg, "🚫 Отклик невозможен\nОбъявление закрыто работодателем.", alert=True)
        else:
            await cb_or_msg.answer("🚫 Отклик невозможен\nОбъявление закрыто работодателем.")
        return None

    if bool(payload.get("expired_auto")):
        if isinstance(cb_or_msg, CallbackQuery):
            await safe_answer(cb_or_msg, "🚫 Вакансия больше не актуальна.\nОтклик невозможен.", alert=True)
        else:
            await cb_or_msg.answer("🚫 Вакансия больше не актуальна.\nОтклик невозможен.")
        return None

    if getattr(ad, "created_at", None) and _ad_is_expired(ad.created_at):
        if isinstance(cb_or_msg, CallbackQuery):
            await safe_answer(cb_or_msg, "🚫 Это объявление устарело.\nОтклик невозможен.", alert=True)
        else:
            await cb_or_msg.answer("🚫 Это объявление устарело.\nОтклик невозможен.")
        return None

    return ad


async def start_from_deeplink(message: Message, ad_id: int, *, state: FSMContext | None = None, redis: Any = None):

    # 🔥 ANTI-RACE LOCK
    if not await _acquire_click_lock(redis, int(message.from_user.id), int(ad_id)):
        return

    ad = await _guard_ad_for_respond(message, int(ad_id))
    if not ad:
        return

            # 1) Приоритет №1: если отклик уже существует в БД — показываем напоминание
    try:
        async with get_sessionmaker()() as session:
            existing = await _find_existing_candidate_respond(
                session,
                int(ad_id),
                int(message.from_user.id),
            )

        if existing:
            await _show_existing_candidate_respond_notice(
                bot=message.bot,
                redis=redis,
                user_id=int(message.from_user.id),
                ad=ad,
                respond=existing,
                state=state,
            )
            return
    except Exception:
        logger.exception(
            "start_from_deeplink: existing respond notice failed user_id=%s ad_id=%s",
            message.from_user.id,
            ad_id,
        )

    text = _respond_intro_text(ad)

    # 2) Если готового отклика нет — работаем с draft-flow.
    if state is not None:
        try:
            data = await state.get_data()

            same_ad_unfinished = _draft_belongs_to_ad(data, int(ad_id)) and _has_unfinished_draft_payload(data)
            other_ad_unfinished = (
                _has_unfinished_draft_payload(data)
                and not _draft_belongs_to_ad(data, int(ad_id))
            )

            if same_ad_unfinished:
                with contextlib.suppress(Exception):
                    await _cleanup_form_flow(message.bot, state, int(message.chat.id))
                await state.update_data(ad_id=int(ad_id), editing_field=None)
                await _upsert_intro_message(
                    message.bot,
                    redis,
                    int(message.from_user.id),
                    int(ad_id),
                    _respond_draft_choice_text(),
                    reply_markup=draft_choice_kb(),
                )
                return

            if other_ad_unfinished:
                await _hard_reset_draft_flow(
                    bot=message.bot,
                    state=state,
                    chat_id=int(message.chat.id),
                    redis=redis,
                )
            else:
                await state.clear()
                await reset_cleanup_bucket(state)
        except Exception:
            logger.exception("start_from_deeplink: draft flow check/reset failed user_id=%s ad_id=%s", message.from_user.id, ad_id)
            with contextlib.suppress(Exception):
                await state.clear()
                await reset_cleanup_bucket(state)

    await _upsert_intro_message(
        message.bot,
        redis,
        int(message.from_user.id),
        int(ad_id),
        text,
    )


