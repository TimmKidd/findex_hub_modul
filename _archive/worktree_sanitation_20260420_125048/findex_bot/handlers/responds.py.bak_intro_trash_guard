async def _cleanup_resurrection_pings(bot, respond_id: int, user_id: int) -> None:
    async with get_sessionmaker()() as session:
        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return

        structured = _ensure_structured(getattr(r, "structured", None))
        msgs = structured.get("resurrection_messages") or []

        if not msgs:
            return

        is_author = int(user_id) == int(getattr(r, "author_user_id", 0) or 0)
        is_candidate = int(user_id) == int(getattr(r, "candidate_user_id", 0) or 0)

        if not is_author and not is_candidate:
            return

        keep: list[dict[str, Any]] = []

        for item in msgs:
            if not isinstance(item, dict):
                continue

            try:
                chat_id = int(item.get("chat_id"))
                message_id = int(item.get("message_id"))
                side = str(item.get("side") or "").strip()
            except Exception:
                continue

            should_delete = (
                (is_author and side == "author")
                or
                (is_candidate and side == "candidate")
            )

            if should_delete:
                with contextlib.suppress(Exception):
                    await bot.delete_message(chat_id=chat_id, message_id=message_id)
            else:
                keep.append(item)

        structured["resurrection_messages"] = keep
        r.structured = structured  # type: ignore

        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        await session.commit()


