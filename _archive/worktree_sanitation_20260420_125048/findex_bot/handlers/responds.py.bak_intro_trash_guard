        return await safe_answer(cb, "⏳ Подожди...", alert=False)

    ad = await _guard_ad_for_respond(cb, ad_id)
    if not ad:
        return

    # ✅ 1. если уже есть отклик → показываем видимое напоминание + кнопку открытия карточки
    async with get_sessionmaker()() as session:
        existing = await _find_existing_candidate_respond(
