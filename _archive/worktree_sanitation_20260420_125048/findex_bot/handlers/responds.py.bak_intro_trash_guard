def _extract_browse_context_from_markup(markup) -> tuple[bool, str | None, str | None, int | None]:
    """
    Пытаемся восстановить browse-context из текущей inline-клавиатуры карточки.
    Нужен для случаев, когда карточка открыта из списка откликов, а callback_data
    рабочей кнопки (например cancel/close) не содержит side/bucket/page.
    """
    try:
        if not markup or not getattr(markup, "inline_keyboard", None):
            return False, None, None, None

        for row in markup.inline_keyboard:
            for btn in row:
                cb = getattr(btn, "callback_data", None) or ""
                if not cb.startswith("menu_responds_bucket:"):
                    continue

                parts = cb.split(":")
                if len(parts) != 4:
                    continue

                    # no-op

                side = parts[1].strip()
                bucket = parts[2].strip()
                page = int(parts[3])

                if side not in {"candidate", "author"}:
                    continue
                if bucket not in {"active", "closed"}:
                    continue

                return True, side, bucket, page
    except Exception:
        logger.exception("_extract_browse_context_from_markup failed")

    return False, None, None, None


