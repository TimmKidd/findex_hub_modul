def _pick_channel_message_id(ad: Ad) -> Optional[int]:
    payload = getattr(ad, "payload", None) or {}
    candidates = [
        payload.get("main_message_id"),
        payload.get("main_channel_message_id"),
        payload.get("channel_message_id"),
        payload.get("published_message_id"),
        payload.get("published_post_id"),
        payload.get("channel_post_id"),
    ]
    for v in candidates:
        try:
            if v is None:
                continue
            x = int(v)
            if x > 0:
                return x
        except Exception:
            continue
    return None


def _channel_post_url_from_ad(ad: Ad) -> Optional[str]:
    try:
        u = getattr(ad, "public_url", None)
        if u:
            u = str(u).strip()
            if u:
                return u
    except Exception:
        pass

    payload = getattr(ad, "payload", None) or {}
    try:
        u2 = payload.get("public_url")
        if u2:
            u2 = str(u2).strip()
            if u2:
                return u2
    except Exception:
        pass

    username = (getattr(runtime, "CHANNEL_USERNAME", "") or "").strip().lstrip("@")
    if not username:
        return None

    msg_id = _pick_channel_message_id(ad)
    if not msg_id:
        return None

    return f"https://t.me/{username}/{msg_id}"


def _shorten(text: str, limit: int = 3400) -> str:
    text = text or ""
    if len(text) <= limit:
        return text
    return text[: (limit - 60)].rstrip() + "\n\n…(история переписки укорочена)"


def _ensure_structured(value: dict | None) -> dict[str, Any]:
    s = dict(value) if isinstance(value, dict) else {}

    thread = s.get("thread")
    if not isinstance(thread, list):
        s["thread"] = []

    collapsed = s.get("collapsed")
    if not isinstance(collapsed, dict):
        collapsed = {}
    collapsed.setdefault("author", False)
    collapsed.setdefault("candidate", False)
    s["collapsed"] = collapsed

    candidate_profile = s.get("candidate_profile")
    if not isinstance(candidate_profile, dict):
        s["candidate_profile"] = {}

    resurrection_messages = s.get("resurrection_messages")
    if not isinstance(resurrection_messages, list):
        s["resurrection_messages"] = []

    return s


def _append_thread(structured: dict | None, by: str, text: str) -> dict:
    s = _ensure_structured(structured)
    thread = s["thread"]
    thread.append({"ts": _now_utc().isoformat(), "by": by, "text": (text or "").strip()})
    if len(thread) > 60:
        thread = thread[-60:]
    s["thread"] = thread
    return s


def _render_thread(structured: dict | None) -> str:
    s = _ensure_structured(structured)
    thread = s["thread"]
    if not thread:
        return "—"

    lines: list[str] = []
    for item in thread:
        try:
            by = str(item.get("by") or "")
            txt = str(item.get("text") or "").strip()
        except Exception:
            continue
        if not txt:
            continue
        prefix = "👤 Кандидат" if by == "candidate" else "🧑‍💼 Работодатель"
        lines.append(f"<b>{prefix}:</b> {_h(txt)}")
    return "\n\n".join(lines) if lines else "—"


