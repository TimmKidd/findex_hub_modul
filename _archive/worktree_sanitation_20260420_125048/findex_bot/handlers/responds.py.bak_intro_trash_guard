            with contextlib.suppress(Exception):
                await _clear_intro_message(redis, int(user_id), int(ad_id))

            if state is not None:
                with contextlib.suppress(Exception):
                    await _hard_reset_draft_flow(
                        bot=bot,
                        state=state,
                        chat_id=int(user_id),
                        redis=redis,
                    )

            ok = await _upsert_card_for_view(bot, session, r, ad, view="candidate")
            if not ok:
                return False

            await session.commit()

        if respond_id:
            with contextlib.suppress(Exception):
                await _set_active_respond(redis, int(user_id), int(respond_id))
            with contextlib.suppress(Exception):
                await _cleanup_resurrection_pings(bot, int(respond_id), int(user_id))

        return True
    except Exception:
        logger.exception(
            "_open_existing_candidate_respond failed user_id=%s ad_id=%s respond_id=%s",
            user_id,
            ad_id,
            respond_id,
        )
        return False


