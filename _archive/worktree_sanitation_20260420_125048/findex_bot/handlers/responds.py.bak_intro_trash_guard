async def _edit_or_send(
    *,
    cb: CallbackQuery | None = None,
    message: Message | None = None,
    bot=None,
    chat_id: int,
    text: str,
    reply_markup=None,
    parse_mode: ParseMode | None = ParseMode.HTML,
) -> bool:
    lp = LinkPreviewOptions(is_disabled=True)

    if cb is not None and cb.message is not None:
        try:
            await cb.message.edit_text(
                text=text,
                parse_mode=parse_mode,
                reply_markup=reply_markup,
                link_preview_options=lp,
            )
            return True
        except Exception as e:
            if "message is not modified" in str(e).lower():
                return True
            logger.warning("edit_text failed -> fallback to send_message: %r", e)

    if message is not None:
        try:
            await message.edit_text(
                text=text,
                parse_mode=parse_mode,
                reply_markup=reply_markup,
                link_preview_options=lp,
            )
            return True
        except Exception as e:
            if "message is not modified" in str(e).lower():
                return True

    try:
        if bot is None:
            bot = (cb.bot if cb is not None else (message.bot if message is not None else None))
        if bot is None:
            return False
        await bot.send_message(
            chat_id=int(chat_id),
            text=text,
            parse_mode=parse_mode,
            reply_markup=reply_markup,
            link_preview_options=lp,
        )
        return True
    except Exception as e:
        logger.warning("send_message failed in _edit_or_send(): %r", e)
        return False


def _normalize_other_citizenship(raw: str) -> str | None:
    s = " ".join((raw or "").strip().split())
    if not s:
        return None

    if len(s) < 2 or len(s) > 40:
        return None

    allowed_extra = {" ", "-"}
    for ch in s:
        if ch.isdigit():
            return None
        if ch.isalpha():
            continue
        if ch in allowed_extra:
            continue
        return None

    letters = [ch.lower() for ch in s if ch.isalpha()]
    if len(letters) < 2:
        return None
    if len(set(letters)) <= 1 and len(letters) >= 3:
        return None

    return s


