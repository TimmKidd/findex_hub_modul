@router.callback_query(F.data.startswith(f"{CB_RESUME}:"))
async def resume_respond(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        repo = RespondRepo(session)

        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        uid = int(cb.from_user.id)

        if uid == int(getattr(r, "author_user_id", 0) or 0):
            view = "author"
            try:
                fn = getattr(repo, "mark_owner_viewed_if_null", None)
                if callable(fn):
                    await fn(int(respond_id))
                r = await session.get(Respond, int(respond_id)) or r
            except Exception:
                logger.exception("resume_respond: mark_owner_viewed_if_null failed respond_id=%s", respond_id)

            ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
            if not ad:
                return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

            ok = await _upsert_card_for_view(cb.bot, session, r, ad, view=view)
            if not ok:
                return await safe_answer(cb, "⚠️ Не удалось открыть отклик", alert=True)

            await session.commit()

        elif uid == int(getattr(r, "candidate_user_id", 0) or 0):
            ad_id = int(getattr(r, "ad_id", 0) or 0)
            if not ad_id:
                return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

            opened = await _open_existing_candidate_respond(
                bot=cb.bot,
                ad_id=ad_id,
                user_id=int(cb.from_user.id),
                state=None,
                redis=redis,
            )
            if not opened:
                return await safe_answer(cb, "⚠️ Не удалось открыть отклик", alert=True)

        else:
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

    try:
        await _set_active_respond(redis, int(cb.from_user.id), int(respond_id))
    except Exception:
        logger.exception(
            "resume_respond: failed to set active respond user_id=%s respond_id=%s",
            cb.from_user.id,
            respond_id,
        )

    try:
        await _cleanup_resurrection_pings(cb.bot, int(respond_id), int(cb.from_user.id))
    except Exception:
        logger.exception(
            "resume_respond: resurrection cleanup failed respond_id=%s user_id=%s",
            respond_id,
            cb.from_user.id,
        )


@router.callback_query(F.data.startswith(f"{CB_OPEN_FROM_LIST}:"))
async def open_respond_from_list(cb: CallbackQuery):
    await safe_answer(cb)

    parts = (cb.data or "").split(":")
    if len(parts) != 5:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    try:
        respond_id = int(parts[1])
        side = parts[2].strip()
        bucket = parts[3].strip()
        page = int(parts[4])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    if side not in {"candidate", "author"} or bucket not in {"active", "closed"}:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        repo = RespondRepo(session)

        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        uid = int(cb.from_user.id)
        if side == "author":
            if uid != int(getattr(r, "author_user_id", 0) or 0):
                return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)
            view = "author"
            try:
                fn = getattr(repo, "mark_owner_viewed_if_null", None)
                if callable(fn):
                    await fn(int(respond_id))
                r = await session.get(Respond, int(respond_id)) or r
            except Exception:
                logger.exception("open_respond_from_list: mark_owner_viewed_if_null failed respond_id=%s", respond_id)
        else:
            if uid != int(getattr(r, "candidate_user_id", 0) or 0):
                return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)
            view = "candidate"

        ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
        if not ad:
            return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

        text = _text_for(ad, r, view=view)
        kb = _kb_for(
            r,
            view=view,
            browse_mode=True,
            side=side,
            bucket=bucket,
            page=page,
        )

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=kb,
        parse_mode=ParseMode.HTML,
    )


