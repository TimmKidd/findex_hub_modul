# ---------------- CONFIG ----------------
@dataclass
class Config:
    bot_token: str
    moderation_chat_id: int
    main_channel_id: int
    thread_vacancies: int
    channel_username: str


def _resolve_env_path() -> str:
    env_path = (os.getenv("ENV_PATH") or "").strip()
    if env_path:
        return env_path

    project_root = Path(__file__).resolve().parent.parent
    return str(project_root / ".env")


def load_config() -> Config:
    env_path = _resolve_env_path()
    load_dotenv(env_path, override=False)

    token = os.getenv("BOT_TOKEN")
    if not token:
        raise RuntimeError(f"BOT_TOKEN not set in env file: {env_path}")

    moderation_chat_id = int(os.getenv("MODERATION_CHAT_ID", 0) or 0)
    if moderation_chat_id == 0:
        raise RuntimeError(f"MODERATION_CHAT_ID not set (or equals 0) in env file: {env_path}")

    return Config(
        bot_token=token,
        moderation_chat_id=moderation_chat_id,
        main_channel_id=int(os.getenv("MAIN_CHANNEL_ID", 0) or 0),
        thread_vacancies=int(os.getenv("THREAD_VACANCIES", 0) or 0),
        channel_username=os.getenv("CHANNEL_USERNAME", "") or "",
    )


config = load_config()

