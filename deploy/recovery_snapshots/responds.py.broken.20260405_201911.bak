    try:
        await reset_cleanup_bucket(state)
    except Exception:
        logger.exception("reset_cleanup_bucket failed chat_id=%s", chat_id)


async def _send_ephemeral_notice(bot, chat_id: int, text: str, *, seconds: int = REJECT_NOTICE_DELETE_SEC) -> None:
    try:
        m = await bot.send_message(
            chat_id=int(chat_id),
            text=text,
            link_preview_options=LinkPreviewOptions(is_disabled=True),
        )
    except Exception:
        logger.exception("send_ephemeral_notice: send_message failed chat_id=%s", chat_id)
        return

    try:
        await asyncio.sleep(int(seconds))
    except Exception:
        logger.exception("send_ephemeral_notice: sleep failed chat_id=%s", chat_id)
        return

    with contextlib.suppress(Exception):
        await bot.delete_message(chat_id=int(chat_id), message_id=int(m.message_id))


async def _safe_delete_user_message(message: Message | None) -> None:
    if message is None:
        return
    with contextlib.suppress(Exception):
        await message.delete()


async def _intro_hint_lock(redis: Any, user_id: int, *, ttl_sec: int = 3) -> bool:
    if not redis:
        return True
    try:
        r = _get_redis(redis)
        key = f"respond:intro_hint_lock:{int(user_id)}"
        ok = await r.set(key, "1", nx=True, ex=int(ttl_sec))
        return bool(ok)
    except Exception:
        logger.exception("_intro_hint_lock failed user_id=%s", user_id)
        return True


async def _send_intro_trash_hint(bot, redis: Any, user_id: int) -> None:
    ok = await _intro_hint_lock(redis, int(user_id), ttl_sec=3)
    if not ok:
        return

    await _send_ephemeral_notice(
        bot,
        int(user_id),
        "👇 Нажми кнопку «⚡ Откликнуться за 1 минуту» ниже.\n"
        "На этом этапе не нужно отправлять сообщение вручную.",
        seconds=3,
    )


async def _cleanup_resurrection_pings(bot, respond_id: int, user_id: int) -> None:
    async with get_sessionmaker()() as session:
        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return

        structured = _ensure_structured(getattr(r, "structured", None))
        msgs = structured.get("resurrection_messages") or []

        if not msgs:
            return

        is_author = int(user_id) == int(getattr(r, "author_user_id", 0) or 0)
        is_candidate = int(user_id) == int(getattr(r, "candidate_user_id", 0) or 0)

        if not is_author and not is_candidate:
            return

        keep: list[dict[str, Any]] = []

        for item in msgs:
            if not isinstance(item, dict):
                continue

            try:
                chat_id = int(item.get("chat_id"))
                message_id = int(item.get("message_id"))
                side = str(item.get("side") or "").strip()
            except Exception:
                continue

            should_delete = (
                (is_author and side == "author")
                or
                (is_candidate and side == "candidate")
            )

            if should_delete:
                with contextlib.suppress(Exception):
                    await bot.delete_message(chat_id=chat_id, message_id=message_id)
            else:
                keep.append(item)

        structured["resurrection_messages"] = keep
        r.structured = structured  # type: ignore

        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        await session.commit()


async def _purge_all_resurrection_refs(bot, respond_id: int) -> None:
    async with get_sessionmaker()() as session:
        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return

        structured = _ensure_structured(getattr(r, "structured", None))
        msgs = structured.get("resurrection_messages") or []

        for item in msgs:
            if not isinstance(item, dict):
                continue
            with contextlib.suppress(Exception):
                chat_id = int(item.get("chat_id"))
                message_id = int(item.get("message_id"))
                await bot.delete_message(chat_id=chat_id, message_id=message_id)

        structured["resurrection_messages"] = []
        r.structured = structured  # type: ignore

        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        await session.commit()


_ME_USERNAME_CACHE: Optional[str] = None


async def _deeplink_url(bot, ad_id: int) -> Optional[str]:
    global _ME_USERNAME_CACHE

    username = (getattr(runtime, "BOT_USERNAME", "") or "").strip().lstrip("@")
    if not username:
        if _ME_USERNAME_CACHE:
            username = _ME_USERNAME_CACHE
        else:
            try:
                me = await bot.get_me()
                username = (getattr(me, "username", "") or "").strip().lstrip("@")
                if username:
                    _ME_USERNAME_CACHE = username
            except Exception:
                username = ""

    if not username:
        return None

    return f"https://t.me/{username}?start=resp_{int(ad_id)}"


async def _edit_or_send(
    *,
    cb: CallbackQuery | None = None,
    message: Message | None = None,
    bot=None,
    chat_id: int,
    text: str,
    reply_markup=None,
    parse_mode: ParseMode | None = ParseMode.HTML,
) -> bool:
    lp = LinkPreviewOptions(is_disabled=True)

    if cb is not None and cb.message is not None:
        try:
            await cb.message.edit_text(
                text=text,
                parse_mode=parse_mode,
                reply_markup=reply_markup,
                link_preview_options=lp,
            )
            return True
        except Exception as e:
            if "message is not modified" in str(e).lower():
                return True

    if cb.message is not None:
        with contextlib.suppress(Exception):
            await _store_intro_message(redis, int(cb.from_user.id), int(ad_id), int(cb.message.message_id))
    else:
        with contextlib.suppress(Exception):
            await _upsert_intro_message(
                cb.bot,
                redis,
                int(cb.from_user.id),
                int(ad_id),
                text,
            )



@router.message(RespondFSM.form_intro_choice)
async def intro_choice_clean_thread_guard(message: Message, state: FSMContext, redis: Any = None):
    """
    Clean-thread guard ТОЛЬКО для intro-card этапа.
    Пока пользователь не нажал кнопку «Откликнуться за 1 минуту»,
    любые ручные сообщения считаются мусором:
    - удаляем сообщение
    - показываем короткий автоудаляемый hint
    """
    # Команды не ломаем — пусть идут дальше по другим роутерам
    if (message.text or "").startswith("/"):
        return

    await _safe_delete_user_message(message)
    await _send_intro_trash_hint(message.bot, redis, int(message.from_user.id))


