def _h(v: Any) -> str:
    return html.escape(str(v or ""), quote=False)


def _get_redis(redis: Any) -> Any:
    r = redis or getattr(runtime, "REDIS", None)
    if r is None:
        raise RuntimeError("Redis is not available (no DI, runtime.REDIS is None)")
    return r


async def _set_active_respond(redis: Any, user_id: int, respond_id: int) -> None:
    r = _get_redis(redis)
    key = ACTIVE_KEY.format(user_id=int(user_id))
    await r.set(key, str(int(respond_id)), ex=int(ACTIVE_TTL_SEC))


def _ad_is_expired(ad_created_at: datetime) -> bool:
    dt = ad_created_at
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt < (_now_utc() - timedelta(days=AD_TTL_DAYS))


def _pick_channel_message_id(ad: Ad) -> Optional[int]:
    payload = getattr(ad, "payload", None) or {}
    candidates = [
        payload.get("main_message_id"),
        payload.get("main_channel_message_id"),
        payload.get("channel_message_id"),
        payload.get("published_message_id"),
        payload.get("published_post_id"),
        payload.get("channel_post_id"),
    ]
    for v in candidates:
        try:
            if v is None:
                continue
            x = int(v)
            if x > 0:
                return x
        except Exception:
            continue
    return None


def _channel_post_url_from_ad(ad: Ad) -> Optional[str]:
    try:
        u = getattr(ad, "public_url", None)
        if u:
            u = str(u).strip()
            if u:
                return u
    except Exception:
        pass

    payload = getattr(ad, "payload", None) or {}
    try:
        u2 = payload.get("public_url")
        if u2:
            u2 = str(u2).strip()
            if u2:
                return u2
    except Exception:
        pass

    username = (getattr(runtime, "CHANNEL_USERNAME", "") or "").strip().lstrip("@")
    if not username:
        return None

    msg_id = _pick_channel_message_id(ad)
    if not msg_id:
        return None

    return f"https://t.me/{username}/{msg_id}"


def _shorten(text: str, limit: int = 3400) -> str:
    text = text or ""
    if len(text) <= limit:
        return text
    return text[: (limit - 60)].rstrip() + "\n\n…(история переписки укорочена)"


def _ensure_structured(value: dict | None) -> dict[str, Any]:
    s = dict(value) if isinstance(value, dict) else {}

    thread = s.get("thread")
    if not isinstance(thread, list):
        s["thread"] = []

    collapsed = s.get("collapsed")
    if not isinstance(collapsed, dict):
        collapsed = {}
    collapsed.setdefault("author", False)
    collapsed.setdefault("candidate", False)
    s["collapsed"] = collapsed

    candidate_profile = s.get("candidate_profile")
    if not isinstance(candidate_profile, dict):
        s["candidate_profile"] = {}

    resurrection_messages = s.get("resurrection_messages")
    if not isinstance(resurrection_messages, list):
        s["resurrection_messages"] = []

    return s


def _append_thread(structured: dict | None, by: str, text: str) -> dict:
    s = _ensure_structured(structured)
    thread = s["thread"]
    thread.append({"ts": _now_utc().isoformat(), "by": by, "text": (text or "").strip()})
    if len(thread) > 60:
        thread = thread[-60:]
    s["thread"] = thread
    return s


def _render_thread(structured: dict | None) -> str:
    s = _ensure_structured(structured)
    thread = s["thread"]
    if not thread:
        return "—"

    lines: list[str] = []
    for item in thread:
        try:
            by = str(item.get("by") or "")
            txt = str(item.get("text") or "").strip()
        except Exception:
            continue
        if not txt:
            continue
        prefix = "👤 Кандидат" if by == "candidate" else "🧑‍💼 Работодатель"
        lines.append(f"<b>{prefix}:</b> {_h(txt)}")
    return "\n\n".join(lines) if lines else "—"


def _candidate_profile_from_state(data: dict) -> dict[str, Any]:
    prof: dict[str, Any] = {}
    prof["name"] = (data.get("form_name") or "").strip()
    prof["age"] = (data.get("form_age") or "").strip()
    prof["citizenship"] = (data.get("form_citizenship") or "").strip()
    prof["experience"] = (data.get("form_experience") or "").strip()

    resume_kind = data.get("resume_kind")
    if resume_kind == "file":
        prof["resume_file_id"] = data.get("resume_file_id")
        prof["resume_file_name"] = data.get("resume_file_name")
    elif resume_kind == "link":
        prof["resume_link"] = (data.get("resume_link") or "").strip()

    return prof


def _profile_age_int(prof: dict[str, Any]) -> int:
    raw = str(prof.get("age") or "").strip()
    digits = "".join(ch for ch in raw if ch.isdigit())
    return int(digits or "0")


async def _upsert_candidate_profile_from_profile_dict(
    *,
    session,
    user,
    prof: dict[str, Any],
) -> CandidateProfile:
    repo = CandidateProfileRepo(session)

    username = (getattr(user, "username", None) or "").strip().lstrip("@") or None
    first_name = (getattr(user, "first_name", None) or "").strip() or None
    last_name = (getattr(user, "last_name", None) or "").strip() or None

    return await repo.upsert_profile(
        user_id=int(user.id),
        username=username,
        telegram_first_name=first_name,
        telegram_last_name=last_name,
        full_name=str(prof.get("name") or "").strip(),
        age=_profile_age_int(prof),
        citizenship=str(prof.get("citizenship") or "").strip(),
        experience=str(prof.get("experience") or "").strip(),
        resume_link=str(prof.get("resume_link") or "").strip() or None,
        resume_file_id=(str(prof.get("resume_file_id") or "").strip() or None),
        resume_file_name=(str(prof.get("resume_file_name") or "").strip() or None),
        last_responded_at=_now_utc(),
    )


