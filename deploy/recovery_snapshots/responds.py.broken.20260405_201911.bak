        pmid = data.get("prompt_message_id")
        if pmid:
            await message.bot.delete_message(chat_id=int(message.chat.id), message_id=int(pmid))
    with contextlib.suppress(Exception):
        await message.delete()

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)
        r = await rrepo.get_by_id(respond_id)
        if not r:
            logger.warning("cand_reply_text: respond not found respond_id=%s", respond_id)
            await state.clear()
            return
        if int(r.candidate_user_id) != int(message.from_user.id):
            logger.warning("cand_reply_text: access denied respond_id=%s user_id=%s", respond_id, getattr(message.from_user, "id", None))
            await state.clear()
            return

        forbidden = _respond_action_forbidden_text(r, action_label="Отправка сообщения")
        if forbidden:
            logger.info("cand_reply_text: respond not available respond_id=%s", respond_id)
            with contextlib.suppress(Exception):
                await message.bot.send_message(int(message.chat.id), "🔒 Отклик уже закрыт. Сообщение не отправлено.")
            await state.clear()
            return

        st = _norm_status(getattr(r, "status", None))
        if st not in (ST_INVITED, ST_IN_DIALOG):
            logger.info("cand_reply_text: invalid status for reply respond_id=%s status=%s", respond_id, st)
            with contextlib.suppress(Exception):
                await message.bot.send_message(int(message.chat.id), "⏳ Переписка пока недоступна.")
            await state.clear()
            return

        await _append_message_and_update_cards(message.bot, respond_id=respond_id, by="candidate", text=text)

        await rrepo.add_event(
            respond_id=int(respond_id),
            actor_role="candidate",
            actor_user_id=int(message.from_user.id),
            event_type="candidate_message",
            payload={},
        )

    try:
        await _set_active_respond(redis, int(message.from_user.id), int(respond_id))
    except Exception:
        logger.exception("cand_reply_text: failed to set active respond user_id=%s respond_id=%s", getattr(message.from_user, "id", None), respond_id)

    await state.clear()
