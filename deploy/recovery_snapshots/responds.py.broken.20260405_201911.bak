@router.callback_query(F.data.startswith(f"{CB_CIT_PICK}:"))
async def citizenship_pick(cb: CallbackQuery, state: FSMContext):
    await safe_answer(cb)

    try:
        code = (cb.data or "").split(":", 1)[1].strip()
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    title = CITIZENSHIP_MAP.get(code)
    if not title:
        return await safe_answer(cb, "⚠️ Страна не найдена", alert=True)

    await state.update_data(form_citizenship=title)

    data = await state.get_data()
    if data.get("editing_field") == "citizenship":
        await state.update_data(editing_field=None)
        if cb.message:
            with contextlib.suppress(Exception):
                await cb.bot.delete_message(chat_id=int(cb.from_user.id), message_id=int(cb.message.message_id))
        return await _send_form_preview_from_state(cb.bot, int(cb.from_user.id), state)

    text = "4/4 Введи <b>Опыт</b> (обязательно)."
    delivered = await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=None,
        parse_mode=ParseMode.HTML,
    )
    if not delivered:
        m = await cb.bot.send_message(
            chat_id=int(cb.from_user.id),
            text=text,
            parse_mode=ParseMode.HTML,
            link_preview_options=LinkPreviewOptions(is_disabled=True),
        )
        await _track_form_bot_message(state, m)

    await state.set_state(RespondFSM.form_experience)


