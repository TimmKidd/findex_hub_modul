@router.message(RespondFSM.form_name)
async def form_step_name(message: Message, state: FSMContext):
    await _track_form_user_message(state, message)

    name = (message.text or "").strip()
    if not name:
        m = await message.answer("⚠️ Имя обязательно. Введи имя одним сообщением.")
        await _track_form_bot_message(state, m)
        return

    await state.update_data(form_name=name)

    data = await state.get_data()
    if data.get("editing_field") == "name":
        await state.update_data(editing_field=None)
        with contextlib.suppress(Exception):
            await message.delete()
        with contextlib.suppress(Exception):
            await state.set_state(RespondFSM.form_preview)
            await state.update_data(
                clean_thread_hint_key="respond_form_preview",
                clean_thread_hint_ts=0,
            )
        return await _send_form_preview_from_state(message.bot, int(message.chat.id), state)

    m = await message.answer("2/4 Введи <b>Возраст</b> (обязательно).", parse_mode=ParseMode.HTML)
    await _track_form_bot_message(state, m)
    await state.set_state(RespondFSM.form_age)


@router.message(RespondFSM.form_age)
async def form_step_age(message: Message, state: FSMContext):
    await _track_form_user_message(state, message)

    raw = (message.text or "").strip()
    if not raw:
        m = await message.answer("⚠️ Возраст обязателен. Введи возраст одним сообщением (числом).")
        await _track_form_bot_message(state, m)
        return

    digits = "".join(ch for ch in raw if ch.isdigit())
    if not digits:
        m = await message.answer("⚠️ Возраст нужен числом. Пример: 25")
        await _track_form_bot_message(state, m)
        return

    try:
        a = int(digits)
    except Exception:
        m = await message.answer("⚠️ Возраст нужен числом. Пример: 25")
        await _track_form_bot_message(state, m)
        return

    if a < 14 or a > 80:
        m = await message.answer("⚠️ Возраст должен быть от 14 до 80.")
        await _track_form_bot_message(state, m)
        return

    await state.update_data(form_age=str(a))

    data = await state.get_data()

    text = (
        "3/4 Выбери <b>Гражданство</b> (обязательно).\n\n"
        "Если твоей страны нет в списке — нажми «🌍 Другая страна»."
    )

    if data.get("editing_field") == "age":
        await state.update_data(editing_field=None)
        with contextlib.suppress(Exception):
            await message.delete()
        with contextlib.suppress(Exception):
            await state.set_state(RespondFSM.form_preview)
            await state.update_data(
                clean_thread_hint_key="respond_form_preview",
                clean_thread_hint_ts=0,
            )
        return await _send_form_preview_from_state(message.bot, int(message.chat.id), state)

    m = await message.answer(
        text,
        parse_mode=ParseMode.HTML,
        reply_markup=citizenship_kb(),
    )
    await _track_form_bot_message(state, m)
    await state.set_state(RespondFSM.form_citizenship_pick)


@router.message(RespondFSM.form_citizenship_pick)
