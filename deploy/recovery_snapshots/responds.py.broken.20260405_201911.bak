def _has_meaningful_value(v: Any) -> bool:
    if v is None:
        return False
    if isinstance(v, str):
        return bool(v.strip())
    return True


def _has_unfinished_draft_payload(data: dict | None) -> bool:
    if not isinstance(data, dict):
        return False
    return any(_has_meaningful_value(data.get(k)) for k in DRAFT_FLOW_FIELDS)


def _draft_belongs_to_ad(data: dict | None, ad_id: int) -> bool:
    if not isinstance(data, dict):
        return False
    try:
        return int(data.get("ad_id") or 0) == int(ad_id)
    except Exception:
        return False


async def _store_intro_message(redis: Any, user_id: int, ad_id: int, message_id: int) -> None:
    r = _get_redis(redis)
    key = INTRO_KEY.format(user_id=int(user_id), ad_id=int(ad_id))
    await r.set(key, str(int(message_id)), ex=PENDING_RESPOND_TTL_MIN * 60)


async def _load_intro_message(redis: Any, user_id: int, ad_id: int) -> int | None:
    try:
        r = _get_redis(redis)
        key = INTRO_KEY.format(user_id=int(user_id), ad_id=int(ad_id))
        raw = await r.get(key)
        if not raw:
            return None

        if isinstance(raw, bytes):
            raw = raw.decode("utf-8", errors="ignore")

        return int(str(raw).strip())
    except Exception:
        logger.exception("_load_intro_message failed user_id=%s ad_id=%s", user_id, ad_id)
        return None


async def _clear_intro_message(redis: Any, user_id: int, ad_id: int) -> None:
    with contextlib.suppress(Exception):
        r = _get_redis(redis)
        key = INTRO_KEY.format(user_id=int(user_id), ad_id=int(ad_id))
        await r.delete(key)


async def _clear_all_intro_messages(redis: Any, user_id: int) -> None:
    """
    Чистит все intro/service-message ключи пользователя по всем объявлениям.
    Нужен только для полного hard-reset, когда пользователь переключается
    между разными объявлениями или мы сознательно обнуляем весь flow.
    """
    with contextlib.suppress(Exception):
        r = _get_redis(redis)
        pattern = INTRO_KEY.format(user_id=int(user_id), ad_id="*")

        cursor = 0
        while True:
            cursor, keys = await r.scan(cursor=cursor, match=pattern, count=100)
            if keys:
                await r.delete(*keys)
            if cursor == 0:
                break


async def _upsert_intro_message(
    bot,
    redis: Any,
    user_id: int,
    ad_id: int,
    text: str,
    *,
    reply_markup: InlineKeyboardMarkup | None = None,
):
    prev_msg_id = await _load_intro_message(redis, int(user_id), int(ad_id))
    lp = LinkPreviewOptions(is_disabled=True)
    kb = reply_markup or intro_kb(int(ad_id))

    if prev_msg_id:
        try:
            await bot.edit_message_text(
                chat_id=int(user_id),
                message_id=int(prev_msg_id),
                text=text,
                parse_mode=ParseMode.HTML,
                reply_markup=kb,
                link_preview_options=lp,
            )
            await _store_intro_message(redis, int(user_id), int(ad_id), int(prev_msg_id))
            return int(prev_msg_id)
        except Exception as e:
            if "message is not modified" in str(e).lower():
                await _store_intro_message(redis, int(user_id), int(ad_id), int(prev_msg_id))
                return int(prev_msg_id)

            with contextlib.suppress(Exception):
                await bot.delete_message(chat_id=int(user_id), message_id=int(prev_msg_id))

    m = await bot.send_message(
        chat_id=int(user_id),
        text=text,
        parse_mode=ParseMode.HTML,
        reply_markup=kb,
        link_preview_options=lp,
    )
    await _store_intro_message(redis, int(user_id), int(ad_id), int(m.message_id))
    return int(m.message_id)


def _prompt_ad_title(ad: Ad) -> str:
    try:
        payload = getattr(ad, "payload", None) or {}
        return str(payload.get("title") or "").strip() or "—"
    except Exception:
        return "—"


def _prompt_ad_location(ad: Ad) -> str:
    try:
        payload = getattr(ad, "payload", None) or {}
        return str(payload.get("location") or "").strip() or "—"
    except Exception:
        return "—"


def _build_author_reply_prompt(ad: Ad, respond: Respond) -> str:
    ad_num = f"#{int(getattr(ad, 'id', 0) or 0)}"
    title = _prompt_ad_title(ad)
    location = _prompt_ad_location(ad)

    candidate_username = None
    structured = getattr(respond, "structured", None)
    if isinstance(structured, dict):
        v = str(structured.get("candidate_username") or "").strip().lstrip("@")
        if v:
            candidate_username = f"@{v}"

    candidate_label = candidate_username or str(int(getattr(respond, "candidate_user_id", 0) or 0))

    return (
        "✉️ <b>Ответ кандидату</b>\n\n"
        f"Объявление: <code>{_h(ad_num)}</code>\n"
        f"Вакансия: {_h(title)}\n"
        f"Локация: {_h(location)}\n"
        f"Кандидат: {_h(candidate_label)}\n\n"
        "Напиши ответ одним сообщением."
    )


async def _upsert_service_message(
    bot,
    redis: Any,
    user_id: int,
    ad_id: int,
    text: str,
    *,
    reply_markup: InlineKeyboardMarkup | None = None,
    parse_mode: ParseMode | None = ParseMode.HTML,
) -> int:
    prev_msg_id = await _load_intro_message(redis, int(user_id), int(ad_id))
    lp = LinkPreviewOptions(is_disabled=True)

    if prev_msg_id:
        try:
            await bot.edit_message_text(
                chat_id=int(user_id),
                message_id=int(prev_msg_id),
                text=text,
                parse_mode=parse_mode,
                reply_markup=reply_markup,
                link_preview_options=lp,
            )
            await _store_intro_message(redis, int(user_id), int(ad_id), int(prev_msg_id))
            return int(prev_msg_id)

        except Exception as e:
            if "message is not modified" in str(e).lower():
                await _store_intro_message(redis, int(user_id), int(ad_id), int(prev_msg_id))
                return int(prev_msg_id)

            with contextlib.suppress(Exception):
                await bot.delete_message(chat_id=int(user_id), message_id=int(prev_msg_id))

    m = await bot.send_message(
        chat_id=int(user_id),
        text=text,
        parse_mode=parse_mode,
        reply_markup=reply_markup,
        link_preview_options=lp,
    )

    await _store_intro_message(redis, int(user_id), int(ad_id), int(m.message_id))
    return int(m.message_id)


def _build_candidate_reply_prompt(ad: Ad, respond: Respond) -> str:
    ad_num = f"#{int(getattr(ad, 'id', 0) or 0)}"
    title = _prompt_ad_title(ad)
    location = _prompt_ad_location(ad)

    return (
        "✉️ <b>Ответ работодателю</b>\n\n"
        f"Объявление: <code>{_h(ad_num)}</code>\n"
        f"Вакансия: {_h(title)}\n"
        f"Локация: {_h(location)}\n\n"
        "Напиши сообщение одним сообщением."
    )


def _daily_counter_key_and_ttl(user_id: int) -> tuple[str, int]:
    tz = _project_tz()
    now_local = datetime.now(tz)
    next_midnight = (now_local + timedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0)
    ttl = int((next_midnight - now_local).total_seconds())
    if ttl <= 0:
        ttl = 60
    day_key = now_local.strftime("%Y%m%d")
    return DAILY_KEY.format(user_id=int(user_id), day=day_key), ttl


async def _check_and_inc_daily_limit(redis: Any, user_id: int) -> tuple[bool, int]:
    r = _get_redis(redis)
    key, ttl = _daily_counter_key_and_ttl(int(user_id))
    lua = r"""
    local key = KEYS[1]
    local limit = tonumber(ARGV[1])
    local ttl = tonumber(ARGV[2])

    local v = redis.call("GET", key)
    if not v then
      redis.call("SET", key, 1, "EX", ttl)
      return 1
    end

    local n = tonumber(v)
    if not n then
      redis.call("SET", key, 1, "EX", ttl)
      return 1
    end

    if n >= limit then
      return -1
    end

    n = n + 1
    redis.call("SET", key, n, "KEEPTTL")
    return n
    """
    res = await r.eval(lua, 1, key, str(RESPOND_DAILY_LIMIT), str(ttl))
    n = int(res)
    if n == -1:
        return False, RESPOND_DAILY_LIMIT
    return True, n


async def _acquire_submit_lock(redis: Any, user_id: int, ad_id: int) -> tuple[bool, str]:
    r = _get_redis(redis)
    key = SUBMIT_LOCK_KEY.format(user_id=int(user_id), ad_id=int(ad_id))
    token = uuid.uuid4().hex
    ok = await r.set(key, token, ex=20, nx=True)
    return bool(ok), token


async def _acquire_click_lock(redis: Any, user_id: int, ad_id: int, ttl_ms: int = 700) -> bool:
    """
    Анти-спам/анти-гонка на входе.
    """
    if not redis:
        return True

    key = f"respond:click:{user_id}:{ad_id}"

    try:
        ok = await redis.set(key, "1", nx=True, px=ttl_ms)
        return bool(ok)
    except Exception:
        logger.exception("click_lock: redis error user_id=%s ad_id=%s", user_id, ad_id)
        return True


async def _acquire_form_send_click_lock(redis: Any, user_id: int, ad_id: int, ttl_ms: int = 1800) -> bool:
    """
    Короткий anti-race lock именно на кнопку отправки анкеты.
    Нужен, чтобы не пускать повторные callback'и form_send почти одновременно.
    """
    if not redis:
        return True

    key = f"respond:form_send_click:{user_id}:{ad_id}"

    try:
        ok = await redis.set(key, "1", nx=True, px=ttl_ms)
        return bool(ok)
    except Exception:
        logger.exception("form_send_click_lock: redis error user_id=%s ad_id=%s", user_id, ad_id)
        return True


async def _delete_form_preview_message(
    bot,
    state: FSMContext,
    chat_id: int,
    *,
    fallback_message_id: int | None = None,
) -> None:
    """
    Гарантированно удаляет preview-анкету, если она ещё висит.
    Используется в success/duplicate ветках form_send.
    """
    ids: set[int] = set()

    with contextlib.suppress(Exception):
        data = await state.get_data()
        prev_id = data.get("form_preview_message_id")
        if prev_id:
            ids.add(int(prev_id))

    if fallback_message_id:
        ids.add(int(fallback_message_id))

    for msg_id in ids:
        with contextlib.suppress(Exception):
            await bot.delete_message(chat_id=int(chat_id), message_id=int(msg_id))

    with contextlib.suppress(Exception):
        await state.update_data(form_preview_message_id=None)


async def _delete_intro_service_message(
    bot,
    redis: Any,
    user_id: int,
    *,
    ad_id: int | None = None,
) -> None:
    """
    Удаляет intro/service-message.
    - если ad_id передан: удаляет только сообщение этого объявления
    - если ad_id не передан: удаляет все intro/service-message пользователя
    """
    if ad_id is not None:
        prev_msg_id = await _load_intro_message(redis, int(user_id), int(ad_id))
        if prev_msg_id:
            with contextlib.suppress(Exception):
                await bot.delete_message(chat_id=int(user_id), message_id=int(prev_msg_id))

        with contextlib.suppress(Exception):
            await _clear_intro_message(redis, int(user_id), int(ad_id))
        return

    with contextlib.suppress(Exception):
        r = _get_redis(redis)
        pattern = INTRO_KEY.format(user_id=int(user_id), ad_id="*")

        cursor = 0
        keys_to_delete: list[Any] = []

        while True:
            cursor, keys = await r.scan(cursor=cursor, match=pattern, count=100)
            if keys:
                for key in keys:
                    try:
                        raw = await r.get(key)
                        if not raw:
                            continue
                        if isinstance(raw, bytes):
                            raw = raw.decode("utf-8", errors="ignore")
                        msg_id = int(str(raw).strip())
                        with contextlib.suppress(Exception):
                            await bot.delete_message(chat_id=int(user_id), message_id=int(msg_id))
                    except Exception:
                        logger.exception(
                            "_delete_intro_service_message: failed to delete tg message user_id=%s key=%s",
                            user_id,
                            key,
                        )
                keys_to_delete.extend(keys)

            if cursor == 0:
                break

        if keys_to_delete:
            await r.delete(*keys_to_delete)


async def _release_submit_lock(redis: Any, user_id: int, ad_id: int, token: str) -> None:
    with contextlib.suppress(Exception):
        r = _get_redis(redis)
        key = SUBMIT_LOCK_KEY.format(user_id=int(user_id), ad_id=int(ad_id))
        lua = r"""
        local key = KEYS[1]
        local token = ARGV[1]
        local cur = redis.call("GET", key)
        if cur == token then
          return redis.call("DEL", key)
        end
        return 0
        """
        await r.eval(lua, 1, key, token)


async def _track_form_bot_message(state: FSMContext, msg: Message | None) -> None:
    if msg is None:
        return
    with contextlib.suppress(Exception):
        await track_cleanup_message(state, msg, chat_id=int(msg.chat.id))


async def _track_form_user_message(state: FSMContext, msg: Message | None) -> None:
