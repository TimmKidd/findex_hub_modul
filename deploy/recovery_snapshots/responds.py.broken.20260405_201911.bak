    with contextlib.suppress(Exception):
        await track_cleanup_message(state, msg, chat_id=int(msg.chat.id))


async def _cleanup_form_flow(bot, state: FSMContext, chat_id: int, *, keep_ids: list[int] | None = None) -> None:
    try:
        await cleanup_tracked_messages(bot, state, chat_id=int(chat_id), keep_ids=keep_ids or [])
    except Exception:
