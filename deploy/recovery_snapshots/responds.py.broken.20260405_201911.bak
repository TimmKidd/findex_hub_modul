@router.message(RespondFSM.form_resume)
async def form_step_resume(message: Message, state: FSMContext):
    await _track_form_user_message(state, message)

    txt = (message.text or "").strip()

    # подчистить предыдущий invalid-hint, если висит
    data = await state.get_data()
    old_mid = data.get("resume_invalid_hint_message_id")
    if old_mid:
        with contextlib.suppress(Exception):
            await message.bot.delete_message(
                chat_id=int(message.chat.id),
                message_id=int(old_mid),
            )
        with contextlib.suppress(Exception):
            await state.update_data(resume_invalid_hint_message_id=None)

    # вариант: пропустить
    if txt.lower() in ("пропустить", "skip", "нет", "без резюме"):
        await state.update_data(
            resume_kind=None,
            resume_link=None,
            resume_file_id=None,
            resume_file_name=None,
            editing_field=None,
            resume_invalid_hint_message_id=None,
        )
        with contextlib.suppress(Exception):
            await message.delete()
        with contextlib.suppress(Exception):
            await state.set_state(RespondFSM.form_preview)
            await state.update_data(
                clean_thread_hint_key="respond_form_preview",
                clean_thread_hint_ts=0,
            )
        return await _send_form_preview_from_state(message.bot, int(message.chat.id), state)

    # вариант: файл
    if message.document:
        doc = message.document
        await state.update_data(
            resume_kind="file",
            resume_file_id=doc.file_id,
            resume_file_name=(doc.file_name or "resume"),
            resume_link=None,
            editing_field=None,
            resume_invalid_hint_message_id=None,
        )
        with contextlib.suppress(Exception):
            await message.delete()
        with contextlib.suppress(Exception):
            await state.set_state(RespondFSM.form_preview)
            await state.update_data(
                clean_thread_hint_key="respond_form_preview",
                clean_thread_hint_ts=0,
            )
        return await _send_form_preview_from_state(message.bot, int(message.chat.id), state)

    # вариант: ссылка
    if txt and ("http://" in txt or "https://" in txt):
        await state.update_data(
            resume_kind="link",
            resume_link=txt,
            resume_file_id=None,
            resume_file_name=None,
            editing_field=None,
            resume_invalid_hint_message_id=None,
        )
        with contextlib.suppress(Exception):
            await message.delete()
        with contextlib.suppress(Exception):
            await state.set_state(RespondFSM.form_preview)
            await state.update_data(
                clean_thread_hint_key="respond_form_preview",
                clean_thread_hint_ts=0,
            )
        return await _send_form_preview_from_state(message.bot, int(message.chat.id), state)

    # невалидный ввод
    try:
        dbg_state = await state.get_state()
        dbg_data = await state.get_data()
        logger.warning(
            "RESPOND RESUME INVALID DEBUG user_id=%s state=%s hint_key=%s text=%r",
            int(message.from_user.id),
            dbg_state,
            dbg_data.get("clean_thread_hint_key"),
            txt,
        )
    except Exception:
        pass

    with contextlib.suppress(Exception):
        await message.delete()

    m = await message.answer(
        "Здесь нужно:\n"
        "• отправить файл резюме (doc/pdf)\n"
        "• ИЛИ отправить ссылку (http/https)\n"
        "• ИЛИ нажать «⏭️ Пропустить».",
        parse_mode=ParseMode.HTML,
    )
    await state.update_data(resume_invalid_hint_message_id=int(m.message_id))

    async def _cleanup_resume_invalid_hint(chat_id: int, mid: int):
        try:
            await asyncio.sleep(2.5)
            await message.bot.delete_message(
                chat_id=int(chat_id),
                message_id=int(mid),
            )
            logger.warning(
                "RESPOND RESUME HINT DELETE OK chat_id=%s mid=%s",
                int(chat_id),
                int(mid),
            )
        except Exception as e:
            logger.exception(
                "RESPOND RESUME HINT DELETE FAILED chat_id=%s mid=%s err=%r",
                int(chat_id),
                int(mid),
                e,
            )

        try:
            cur = await state.get_data()
            if int(cur.get("resume_invalid_hint_message_id") or 0) == int(mid):
                await state.update_data(resume_invalid_hint_message_id=None)
        except Exception:
            pass

    asyncio.create_task(
        _cleanup_resume_invalid_hint(
            int(message.chat.id),
            int(m.message_id),
        )
    )


@router.callback_query(F.data.startswith(f"{CB_FORM_EDIT}:"))
async def form_edit_field(cb: CallbackQuery, state: FSMContext):
    await safe_answer(cb)

    parts = (cb.data or "").split(":")
    if len(parts) != 3:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    field = parts[1].strip()
    try:
        ad_id = int(parts[2])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    if not cb.message:
        return await safe_answer(cb, "⚠️ Не могу открыть редактор", alert=True)

    await state.update_data(
        ad_id=ad_id,
        form_preview_message_id=int(cb.message.message_id),
        editing_field=field,
    )

    if field == "citizenship":
        text = (
            "3/4 Выбери <b>Гражданство</b> (обязательно).\n\n"
            "Если твоей страны нет в списке — нажми «🌍 Другая страна»."
        )
        await _edit_or_send(
            cb=cb,
            chat_id=int(cb.from_user.id),
            text=text,
            reply_markup=citizenship_kb(),
            parse_mode=ParseMode.HTML,
        )
        await state.set_state(RespondFSM.form_citizenship_pick)
        return

    prompts = {
        "name": ("1/4 Введи <b>Имя</b> (обязательно).", RespondFSM.form_name),
        "age": ("2/4 Введи <b>Возраст</b> (обязательно).", RespondFSM.form_age),
        "experience": ("4/4 Введи <b>Опыт</b> (обязательно).", RespondFSM.form_experience),
        "resume": (
            "📎 <b>Резюме</b> (опционально)\n\n"
            "Пришли:\n"
            "• файл резюме (doc/pdf) ИЛИ\n"
            "• ссылку (Avito / HH / Job.ru / SuperJob)\n\n"
            "Либо нажми «⏭️ Пропустить».",
            RespondFSM.form_resume,
        ),
    }

    if field not in prompts:
        return await safe_answer(cb, "⚠️ Неизвестное поле", alert=True)

    text, st = prompts[field]

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=resume_skip_kb() if field == "resume" else None,
        parse_mode=ParseMode.HTML,
    )

    await state.set_state(st)


@router.callback_query(F.data.startswith(f"{CB_FORM_SEND}:"))
async def form_send(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    parts = (cb.data or "").split(":")
    if len(parts) != 2:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    try:
        ad_id = int(parts[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    # 🔥 отдельный anti-race lock именно на submit preview-анкеты
    if not await _acquire_form_send_click_lock(redis, int(cb.from_user.id), int(ad_id)):
        return await safe_answer(cb, "⏳ Подожди...", alert=False)

    ad = await _guard_ad_for_respond(cb, ad_id)
    if not ad:
        return

    lock_token = ""
    try:
        ok, lock_token = await _acquire_submit_lock(redis, int(cb.from_user.id), int(ad_id))
        if not ok:
            return await safe_answer(cb, "⏳ Отклик уже отправляется. Подожди пару секунд.", alert=True)
    except Exception:
        logger.exception("form_send: failed to acquire submit lock user_id=%s ad_id=%s", cb.from_user.id, ad_id)

    try:
        data = await state.get_data()
        prof = _candidate_profile_from_state(data)

        if not (prof.get("name") and prof.get("age") and prof.get("citizenship") and prof.get("experience")):
            return await safe_answer(cb, "⚠️ Анкета неполная. Заполни все 4 обязательных пункта.", alert=True)

        # ✅ если отклик уже появился — сначала убираем preview, потом открываем карточку
        async with get_sessionmaker()() as session:
            rrepo = RespondRepo(session)
            if await rrepo.respond_exists(ad_id=ad_id, candidate_user_id=int(cb.from_user.id)):
                with contextlib.suppress(Exception):
                    await _delete_form_preview_message(
                        cb.bot,
                        state,
                        int(cb.from_user.id),
                        fallback_message_id=(int(cb.message.message_id) if cb.message else None),
                    )

                opened = await _open_existing_candidate_respond(
                    bot=cb.bot,
                    ad_id=int(ad_id),
                    user_id=int(cb.from_user.id),
                    state=state,
                    redis=redis,
                )
                if opened:
                    return
                return await safe_answer(cb, "🚫 Ты уже откликался на это объявление.", alert=True)

        try:
            allowed, _count = await _check_and_inc_daily_limit(redis, int(cb.from_user.id))
            if not allowed:
                return await safe_answer(
                    cb,
                    "🚫 Лимит откликов исчерпан.\nСегодня можно отправить только 5 откликов.\nПопробуй снова после полуночи.",
                    alert=True,
                )
        except Exception:
            logger.exception("form_send: daily limit check failed user_id=%s", cb.from_user.id)
            return await safe_answer(
                cb,
                "⚠️ Временно не удалось проверить дневной лимит откликов.\nПопробуй ещё раз чуть позже.",
                alert=True,
            )

        cand_username = (getattr(cb.from_user, "username", None) or "").lstrip("@").strip() or None

        structured: dict[str, Any] = _ensure_structured({})
        if cand_username:
            structured["candidate_username"] = cand_username
        structured["candidate_profile"] = prof
        structured = _append_thread(structured, by="candidate", text="Отклик отправлен. Анкета заполнена.")

        try:
            async with get_sessionmaker()() as session:
                rrepo = RespondRepo(session)

                await _upsert_candidate_profile_from_profile_dict(
                    session=session,
                    user=cb.from_user,
                    prof=prof,
                )

                respond = await rrepo.create_respond(
                    ad=ad,
                    candidate_user_id=int(cb.from_user.id),
                    mode="pro",
                    candidate_message="Анкета кандидата",
                    contacts=None,
                    structured=structured,
                    author_chat_id=int(ad.author_user_id),
                    candidate_chat_id=int(cb.from_user.id),
                )

                await rrepo.add_event(
                    respond_id=respond.id,
                    actor_role="candidate",
                    actor_user_id=int(cb.from_user.id),
                    event_type="candidate_responded_form",
                    payload={"mode": "form"},
                )
        except IntegrityError:
            logger.warning("form_send: duplicate respond prevented by DB user_id=%s ad_id=%s", cb.from_user.id, ad_id)

            with contextlib.suppress(Exception):
                await _delete_form_preview_message(
                    cb.bot,
                    state,
                    int(cb.from_user.id),
                    fallback_message_id=(int(cb.message.message_id) if cb.message else None),
                )

            opened = await _open_existing_candidate_respond(
                bot=cb.bot,
                ad_id=int(ad_id),
                user_id=int(cb.from_user.id),
                state=state,
                redis=redis,
            )
            if opened:
                return
            return await safe_answer(cb, "🚫 Ты уже откликался на это объявление.", alert=True)

        # ✅ success branch: preview нужно удалить жёстко и до дальнейшего UI-flow
        with contextlib.suppress(Exception):
            await _delete_form_preview_message(
                cb.bot,
                state,
                int(cb.from_user.id),
                fallback_message_id=(int(cb.message.message_id) if cb.message else None),
            )

        async with get_sessionmaker()() as session3:
            r3 = await session3.get(Respond, int(respond.id))
            a3 = await session3.get(Ad, int(ad_id))
            if not r3 or not a3:
                with contextlib.suppress(Exception):
                    await _cleanup_form_flow(cb.bot, state, int(cb.from_user.id))
                with contextlib.suppress(Exception):
                    await _delete_intro_service_message(
                        cb.bot,
                        redis,
                        int(cb.from_user.id),
                        ad_id=int(ad_id),
                    )
                with contextlib.suppress(Exception):
                    await state.clear()
                return

            await _sync_cards(cb.bot, session3, r3, a3)

        try:
            await _set_active_respond(redis, int(cb.from_user.id), int(respond.id))
        except Exception:
            logger.exception("form_send: failed to set active respond for candidate user_id=%s respond_id=%s", cb.from_user.id, respond.id)

        try:
            await _set_active_respond(redis, int(ad.author_user_id), int(respond.id))
        except Exception:
            logger.exception("form_send: failed to set active respond for author user_id=%s respond_id=%s", ad.author_user_id, respond.id)

        with contextlib.suppress(Exception):
            await _cleanup_form_flow(cb.bot, state, int(cb.from_user.id))
        with contextlib.suppress(Exception):
            await _delete_intro_service_message(
                cb.bot,
                redis,
                int(cb.from_user.id),
                ad_id=int(ad_id),
            )
        with contextlib.suppress(Exception):
            await state.clear()

        return await safe_answer(
            cb,
            "🚀 Отклик отправлен\nРаботодатель уже может ответить",
            alert=True,
        )
    finally:
        if lock_token:
            await _release_submit_lock(redis, int(cb.from_user.id), int(ad_id), lock_token)


async def _store_candidate_invite_notice(session, respond: Respond, chat_id: int, message_id: int) -> None:
    structured = _ensure_structured(getattr(respond, "structured", None))
    structured["cand_invite_notice"] = {"chat_id": int(chat_id), "message_id": int(message_id)}
    respond.structured = dict(structured)  # type: ignore
    with contextlib.suppress(Exception):
        from sqlalchemy.orm.attributes import flag_modified
        flag_modified(respond, "structured")
    await session.commit()


async def _delete_candidate_invite_notice(bot, respond_id: int) -> None:
    async with get_sessionmaker()() as session:
        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return
        structured = _ensure_structured(getattr(r, "structured", None))
        notice = structured.get("cand_invite_notice")
        if not isinstance(notice, dict):
            return

        chat_id = notice.get("chat_id")
        msg_id = notice.get("message_id")
        if not chat_id or not msg_id:
            structured.pop("cand_invite_notice", None)
            r.structured = dict(structured)  # type: ignore
            with contextlib.suppress(Exception):
                from sqlalchemy.orm.attributes import flag_modified
                flag_modified(r, "structured")
            await session.commit()
            return

        try:
            await bot.delete_message(chat_id=int(chat_id), message_id=int(msg_id))
        except Exception:
            logger.exception(
                "delete_candidate_invite_notice: failed to delete tg message respond_id=%s chat_id=%s msg_id=%s",
                respond_id,
                chat_id,
                msg_id,
            )

        structured.pop("cand_invite_notice", None)
        r.structured = dict(structured)  # type: ignore
        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")
        await session.commit()


async def _append_message_and_update_cards(bot, respond_id: int, by: str, text: str) -> None:
    async with get_sessionmaker()() as session:
        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            logger.warning("_append_message_and_update_cards: respond not found respond_id=%s", respond_id)
            return
        ad: Ad | None = await session.get(Ad, int(r.ad_id))
        if not ad:
            logger.warning("_append_message_and_update_cards: ad not found respond_id=%s ad_id=%s", respond_id, getattr(r, "ad_id", None))
            return

        structured = _ensure_structured(getattr(r, "structured", None))
        structured = _append_thread(structured, by=by, text=text)

        r.structured = dict(structured)  # type: ignore
        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        r.status = ST_IN_DIALOG  # type: ignore

        now = _now_utc()
        if by == "candidate":
            r.last_candidate_activity_at = now  # type: ignore
        else:
            r.last_author_activity_at = now  # type: ignore

        await session.commit()

        r = await session.get(Respond, int(respond_id)) or r
        await _sync_cards(bot, session, r, ad)

    if by == "author":
        try:
            await _delete_candidate_invite_notice(bot, int(respond_id))
        except Exception:
            logger.exception("_append_message_and_update_cards: failed to delete invite notice respond_id=%s", respond_id)


@router.callback_query(F.data.startswith(f"{CB_CAND_CANCEL}:"))
async def candidate_cancel(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    browse_mode = False
    side: str | None = None
    bucket: str | None = None
    page: int | None = None

    with contextlib.suppress(Exception):
        browse_mode, side, bucket, page = _extract_browse_context_from_markup(
            getattr(cb.message, "reply_markup", None)
        )

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)
        r = await rrepo.get_by_id(respond_id)
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        if int(r.candidate_user_id) != int(cb.from_user.id):
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

        if _is_closed(getattr(r, "status", None)):
            return await safe_answer(cb, "🔒 Отклик уже закрыт", alert=True)

        await rrepo.set_status(respond_id, ST_CLOSED_BY_CANDIDATE, closed_at=_now_utc())
        with contextlib.suppress(Exception):
            await rrepo.add_event(
                respond_id=int(respond_id),
                actor_role="candidate",
                actor_user_id=int(cb.from_user.id),
                event_type="candidate_closed",
                payload={},
            )

        r2: Respond | None = await session.get(Respond, int(respond_id))
        if not r2:
            return await safe_answer(cb, "✅", alert=True)

        ad: Ad | None = await session.get(Ad, int(r2.ad_id))
        if not ad:
            return await safe_answer(cb, "✅", alert=True)

        await _sync_cards(cb.bot, session, r2, ad)

        text = _text_for(ad, r2, view="candidate")
        kb = _kb_for(
            r2,
            view="candidate",
            browse_mode=browse_mode,
            side=side,
            bucket=bucket,
            page=page,
        )

    with contextlib.suppress(Exception):
        await _delete_candidate_invite_notice(cb.bot, int(respond_id))
    with contextlib.suppress(Exception):
        await _purge_all_resurrection_refs(cb.bot, int(respond_id))

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=kb,
        parse_mode=ParseMode.HTML,
    )

    return await safe_answer(cb, "🚫 Отклик закрыт", alert=True)


@router.callback_query(F.data.startswith(f"{CB_AUTHOR_CLOSE}:") | F.data.startswith(f"{CB_OWNER_CLOSE_ALIAS}:"))
