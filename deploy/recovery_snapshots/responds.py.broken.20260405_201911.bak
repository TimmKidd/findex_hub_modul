@router.callback_query(F.data.startswith(f"{CB_FAST_RESPOND}:"))
async def fast_respond_send(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    try:
        ad_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    if not await _acquire_form_send_click_lock(redis, int(cb.from_user.id), int(ad_id)):
        return await safe_answer(cb, "⏳ Подожди...", alert=False)

    ad = await _guard_ad_for_respond(cb, ad_id)
    if not ad:
        return

    lock_token = ""
    try:
        ok, lock_token = await _acquire_submit_lock(redis, int(cb.from_user.id), int(ad_id))
        if not ok:
            return await safe_answer(cb, "⏳ Отклик уже отправляется. Подожди пару секунд.", alert=True)
    except Exception:
        logger.exception("fast_respond_send: failed to acquire submit lock user_id=%s ad_id=%s", cb.from_user.id, ad_id)

    try:
        async with get_sessionmaker()() as session:
            rrepo = RespondRepo(session)
            existing = await rrepo.respond_exists(ad_id=ad_id, candidate_user_id=int(cb.from_user.id))
            if existing:
                opened = await _open_existing_candidate_respond(
                    bot=cb.bot,
                    ad_id=int(ad_id),
                    user_id=int(cb.from_user.id),
                    state=state,
                    redis=redis,
                )
                if opened:
                    return
                return await safe_answer(cb, "🚫 Ты уже откликался на это объявление.", alert=True)

        try:
            allowed, _count = await _check_and_inc_daily_limit(redis, int(cb.from_user.id))
            if not allowed:
                return await safe_answer(
                    cb,
                    "🚫 Лимит откликов исчерпан.\nСегодня можно отправить только 5 откликов.\nПопробуй снова после полуночи.",
                    alert=True,
                )
        except Exception:
            logger.exception("fast_respond_send: daily limit check failed user_id=%s", cb.from_user.id)
            return await safe_answer(
                cb,
                "⚠️ Временно не удалось проверить дневной лимит откликов.\nПопробуй ещё раз чуть позже.",
                alert=True,
            )

        async with get_sessionmaker()() as session:
            cp_repo = CandidateProfileRepo(session)
            saved_profile = await cp_repo.get_by_user_id(int(cb.from_user.id))
            if not saved_profile:
                return await safe_answer(
                    cb,
                    "⚠️ Сохранённая анкета не найдена.\nЗаполни анкету заново.",
                    alert=True,
                )

        prof = _candidate_profile_from_saved_profile(saved_profile)
        cand_username = (getattr(cb.from_user, "username", None) or "").lstrip("@").strip() or None

        structured: dict[str, Any] = _ensure_structured({})
        if cand_username:
            structured["candidate_username"] = cand_username
        structured["candidate_profile"] = prof
        structured = _append_thread(structured, by="candidate", text="Отклик отправлен по сохранённой анкете.")

        try:
            async with get_sessionmaker()() as session:
                rrepo = RespondRepo(session)
                respond = await rrepo.create_respond(
                    ad=ad,
                    candidate_user_id=int(cb.from_user.id),
                    mode="fast",
                    candidate_message="Сохранённая анкета кандидата",
                    contacts=None,
                    structured=structured,
                    author_chat_id=int(ad.author_user_id),
                    candidate_chat_id=int(cb.from_user.id),
                )

                await CandidateProfileRepo(session).touch_last_responded_at(
                    int(cb.from_user.id),
                    dt=_now_utc(),
                )

                await rrepo.add_event(
                    respond_id=respond.id,
                    actor_role="candidate",
                    actor_user_id=int(cb.from_user.id),
                    event_type="candidate_responded_fast",
                    payload={"mode": "fast"},
                )
        except IntegrityError:
            logger.warning("fast_respond_send: duplicate respond prevented by DB user_id=%s ad_id=%s", cb.from_user.id, ad_id)

            opened = await _open_existing_candidate_respond(
                bot=cb.bot,
                ad_id=int(ad_id),
                user_id=int(cb.from_user.id),
                state=state,
                redis=redis,
            )
            if opened:
                return
            return await safe_answer(cb, "🚫 Ты уже откликался на это объявление.", alert=True)

        async with get_sessionmaker()() as session3:
            r3 = await session3.get(Respond, int(respond.id))
            a3 = await session3.get(Ad, int(ad_id))
            if not r3 or not a3:
                return

            await _sync_cards(cb.bot, session3, r3, a3)

        try:
            await _set_active_respond(redis, int(cb.from_user.id), int(respond.id))
        except Exception:
            logger.exception("fast_respond_send: failed to set active respond for candidate user_id=%s respond_id=%s", cb.from_user.id, respond.id)

        try:
            await _set_active_respond(redis, int(ad.author_user_id), int(respond.id))
        except Exception:
            logger.exception("fast_respond_send: failed to set active respond for author user_id=%s respond_id=%s", ad.author_user_id, respond.id)

        with contextlib.suppress(Exception):
            await _delete_intro_service_message(
                cb.bot,
                redis,
                int(cb.from_user.id),
                ad_id=int(ad_id),
            )

        with contextlib.suppress(Exception):
            await state.clear()

        return await safe_answer(
            cb,
            "🚀 Быстрый отклик отправлен\nРаботодатель уже может ответить",
            alert=True,
        )
    finally:
        if lock_token:
            await _release_submit_lock(redis, int(cb.from_user.id), int(ad_id), lock_token)


async def _send_form_preview_from_state(bot, chat_id: int, state: FSMContext, redis: Any = None) -> None:
    redis = redis or getattr(runtime, "REDIS", None)

    data = await state.get_data()
    ad_id = int(data.get("ad_id") or 0)

    if not ad_id:
        await state.clear()
        with contextlib.suppress(Exception):
            m = await bot.send_message(
                chat_id=int(chat_id),
                text="⚠️ Потерял контекст объявления. Нажми «📩 Откликнуться» ещё раз.",
            )
            await _track_form_bot_message(state, m)
        return

    # 🔥 КРИТИЧНО:
    # если отклик уже существует, preview больше не должна появляться никогда
    try:
        async with get_sessionmaker()() as session:
            rrepo = RespondRepo(session)
            exists = await rrepo.respond_exists(
                ad_id=int(ad_id),
                candidate_user_id=int(chat_id),
            )

        if exists:
            with contextlib.suppress(Exception):
                await _delete_form_preview_message(bot, state, int(chat_id))

            with contextlib.suppress(Exception):
                await _delete_intro_service_message(
                    bot,
                    redis,
                    int(chat_id),
                    ad_id=int(ad_id),
                )

            with contextlib.suppress(Exception):
                await state.clear()

            with contextlib.suppress(Exception):
                await _open_existing_candidate_respond(
                    bot=bot,
                    ad_id=int(ad_id),
                    user_id=int(chat_id),
                    state=state,
                    redis=redis,
                )
            return
    except Exception:
        logger.exception("_send_form_preview_from_state: existing respond check failed chat_id=%s ad_id=%s", chat_id, ad_id)

    prof = _candidate_profile_from_state(data)
    has_resume = _profile_has_resume(prof)

    text = (
        "✅ <b>Проверь анкету</b>\n\n"
        + "\n".join(_render_profile_lines(prof))
        + "\n\n"
        "✏️ Чтобы изменить конкретное поле — нажми на кнопку ниже.\n"
        "Если всё верно — нажми «📨 Отправить отклик»."
    )
    kb = form_preview_kb(ad_id, has_resume=has_resume)

    prev_id = data.get("form_preview_message_id")
    if prev_id:
        try:
            await bot.edit_message_text(
                chat_id=int(chat_id),
                message_id=int(prev_id),
                text=text,
                parse_mode=ParseMode.HTML,
                reply_markup=kb,
                link_preview_options=LinkPreviewOptions(is_disabled=True),
            )
        except Exception as e:
            if "message is not modified" not in str(e).lower():
                logger.warning("edit form preview failed -> send new: %r", e)
                m = await bot.send_message(
                    chat_id=int(chat_id),
                    text=text,
                    parse_mode=ParseMode.HTML,
                    reply_markup=kb,
                    link_preview_options=LinkPreviewOptions(is_disabled=True),
                )
                await state.update_data(form_preview_message_id=int(m.message_id))
                await _track_form_bot_message(state, m)
    else:
        m = await bot.send_message(
            chat_id=int(chat_id),
            text=text,
            parse_mode=ParseMode.HTML,
            reply_markup=kb,
            link_preview_options=LinkPreviewOptions(is_disabled=True),
        )
        await state.update_data(form_preview_message_id=int(m.message_id))
        await _track_form_bot_message(state, m)

    with contextlib.suppress(Exception):
        await state.set_state(RespondFSM.form_preview)
        await state.update_data(
            **{
                "clean_thread_hint_key": "respond_form_preview",
                "clean_thread_hint_ts": 0,
                "form_transient_hint_message_id": None,
                "form_transient_hint_message_id": None,
            }
        )
        try:
            dbg_state = await state.get_state()
            dbg_data = await state.get_data()
            logger.warning(
                "RESPOND PREVIEW DEBUG chat_id=%s state=%s hint_key=%s preview_mid=%s",
                int(chat_id),
                dbg_state,
                dbg_data.get("clean_thread_hint_key"),
                dbg_data.get("form_preview_message_id"),
            )
        except Exception:
            pass
        try:
            dbg_state = await state.get_state()
            dbg_data = await state.get_data()
            logger.warning(
                "RESPOND PREVIEW DEBUG chat_id=%s state=%s hint_key=%s preview_mid=%s",
                int(chat_id),
                dbg_state,
                dbg_data.get("clean_thread_hint_key"),
                dbg_data.get("form_preview_message_id"),
            )
        except Exception:
            pass





async def _upsert_transient_form_hint(
    bot,
    chat_id: int,
    state: FSMContext,
    text: str,
    *,
    ttl_sec: float = 3.0,
) -> None:
    data = await state.get_data()
    prev_id = data.get("form_transient_hint_message_id")

    if prev_id:
        with contextlib.suppress(Exception):
            await bot.delete_message(chat_id=int(chat_id), message_id=int(prev_id))

    m = await bot.send_message(
        chat_id=int(chat_id),
        text=text,
        link_preview_options=LinkPreviewOptions(is_disabled=True),
    )
    await state.update_data(form_transient_hint_message_id=int(m.message_id))

    async def _drop_hint() -> None:
        await asyncio.sleep(ttl_sec)
        with contextlib.suppress(Exception):
            await bot.delete_message(chat_id=int(chat_id), message_id=int(m.message_id))

        try:
            fresh = await state.get_data()
            if int(fresh.get("form_transient_hint_message_id") or 0) == int(m.message_id):
                await state.update_data(form_transient_hint_message_id=None)
        except Exception:
            pass

    asyncio.create_task(_drop_hint())


@router.message(RespondFSM.form_preview)
async def form_preview_clean_thread(message: Message, state: FSMContext):
    raw_text = ((message.text or message.caption or "")).strip()

    if raw_text.startswith("/"):
        return

    with contextlib.suppress(Exception):
        await message.delete()

    data = await state.get_data()
    now_ts = int(time.time())
    last_hint_ts = int(data.get("clean_thread_hint_ts") or 0)

    if (now_ts - last_hint_ts) < 3:
        return

    await state.update_data(clean_thread_hint_ts=now_ts)

    with contextlib.suppress(Exception):
        await _upsert_transient_form_hint(
            message.bot,
            int(message.chat.id),
            state,
            "Используй кнопки выше.",
            ttl_sec=3.0,
        )



async def _upsert_transient_form_hint(
    bot,
    chat_id: int,
    state: FSMContext,
    text: str,
    *,
    ttl_sec: float = 3.0,
) -> None:
    data = await state.get_data()
    prev_id = data.get("form_transient_hint_message_id")

    if prev_id:
        with contextlib.suppress(Exception):
            await bot.delete_message(chat_id=int(chat_id), message_id=int(prev_id))

    m = await bot.send_message(
        chat_id=int(chat_id),
        text=text,
        link_preview_options=LinkPreviewOptions(is_disabled=True),
    )
    await state.update_data(form_transient_hint_message_id=int(m.message_id))

    async def _drop_hint() -> None:
        await asyncio.sleep(ttl_sec)
        with contextlib.suppress(Exception):
            await bot.delete_message(chat_id=int(chat_id), message_id=int(m.message_id))
        try:
            fresh = await state.get_data()
            if int(fresh.get("form_transient_hint_message_id") or 0) == int(m.message_id):
                await state.update_data(form_transient_hint_message_id=None)
        except Exception:
            pass

    asyncio.create_task(_drop_hint())


