@router.callback_query(F.data.startswith(f"{CB_AUTHOR_REJECT}:"))
async def author_reject(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)

        r = await rrepo.get_by_id(respond_id)
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        if int(r.author_user_id) != int(cb.from_user.id):
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

        st = _norm_status(getattr(r, "status", None))
        if st in CLOSED_SET:
            return await safe_answer(cb, "🔒 Отклик уже закрыт", alert=True)

        structured = _ensure_structured(getattr(r, "structured", None))
        structured = _append_thread(structured, by="author", text="Отклик отклонён работодателем.")

        r.structured = dict(structured)  # type: ignore
        r.status = ST_CLOSED_BY_AUTHOR  # type: ignore
        r.closed_at = _now_utc()  # type: ignore

        with contextlib.suppress(Exception):
            from sqlalchemy.orm.attributes import flag_modified
            flag_modified(r, "structured")

        await session.commit()

        r2: Respond | None = await session.get(Respond, int(respond_id))
        if not r2:
            return await safe_answer(cb, "✅", alert=True)

        ad: Ad | None = await session.get(Ad, int(r2.ad_id))
        if not ad:
            return await safe_answer(cb, "✅", alert=True)

        await _sync_cards(cb.bot, session, r2, ad)

        try:
            await _delete_candidate_invite_notice(cb.bot, int(respond_id))
        except Exception:
            logger.exception("author_reject: failed to delete invite notice respond_id=%s", respond_id)

        with contextlib.suppress(Exception):
            await _purge_all_resurrection_refs(cb.bot, int(respond_id))

        await rrepo.add_event(
            respond_id=int(respond_id),
            actor_role="author",
            actor_user_id=int(cb.from_user.id),
            event_type="author_rejected",
            payload={},
        )

        with contextlib.suppress(Exception):
            asyncio.create_task(
                _send_ephemeral_notice(
                    cb.bot,
                    int(r2.candidate_user_id),
                    "🚫 Работодатель отклонил отклик.",
                    seconds=REJECT_NOTICE_DELETE_SEC,
                )
            )

    return await safe_answer(cb, "🚫 Кандидат отклонён", alert=True)


@router.callback_query(F.data.startswith(f"{CB_AUTHOR_INVITE}:") | F.data.startswith(f"{CB_OWNER_INVITE_ALIAS}:"))
async def author_invite(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)

        r = await rrepo.get_by_id(respond_id)
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        if int(r.author_user_id) != int(cb.from_user.id):
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

        st = _norm_status(getattr(r, "status", None))
        if st in CLOSED_SET:
            return await safe_answer(cb, "🔒 Отклик уже закрыт", alert=True)
        if _respond_is_expired(getattr(r, "created_at", None)):
            return await safe_answer(cb, "🔒 Отклик устарел и уже недоступен.", alert=True)
        if st in (ST_INVITED, ST_IN_DIALOG):
            return await safe_answer(cb, "✅ Уже приглашён", alert=True)

        await rrepo.set_invited(int(respond_id))

        r2: Respond | None = await session.get(Respond, int(respond_id))
        if not r2:
            return await safe_answer(cb, "✅", alert=True)

        ad: Ad | None = await session.get(Ad, int(r2.ad_id))
        if not ad:
            return await safe_answer(cb, "✅", alert=True)

        await _sync_cards(cb.bot, session, r2, ad)

        await rrepo.add_event(
            respond_id=int(respond_id),
            actor_role="author",
            actor_user_id=int(cb.from_user.id),
            event_type="author_invited",
            payload={},
        )

    try:
        await _set_active_respond(redis, int(cb.from_user.id), int(respond_id))
    except Exception:
        logger.exception(
            "author_invite: failed to set active respond user_id=%s respond_id=%s",
            cb.from_user.id,
            respond_id,
        )

    return await safe_answer(cb, "✅ Приглашение отправлено", alert=True)


@router.callback_query(F.data.startswith(f"{CB_AUTHOR_REPLY}:") | F.data.startswith(f"{CB_OWNER_REPLY_ALIAS}:"))
async def author_reply_start(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)
        r = await rrepo.get_by_id(respond_id)
        if not r:
            logger.warning("author_reply_start: respond not found respond_id=%s", respond_id)
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)
        if int(r.author_user_id) != int(cb.from_user.id):
            logger.warning("author_reply_start: access denied respond_id=%s user_id=%s", respond_id, cb.from_user.id)
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

        forbidden = _respond_action_forbidden_text(r, action_label="Ответить")
        if forbidden:
            logger.info("author_reply_start: respond not available respond_id=%s", respond_id)
            return await safe_answer(cb, forbidden, alert=True)

        st = _norm_status(getattr(r, "status", None))
        if st not in (ST_INVITED, ST_IN_DIALOG):
            return await safe_answer(cb, "⏳ Сначала пригласи кандидата к следующему этапу.", alert=True)

        ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
        if not ad:
            return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

        prompt_text = _build_author_reply_prompt(ad, r)

    try:
        await _set_active_respond(redis, int(cb.from_user.id), int(respond_id))
    except Exception:
        logger.exception("author_reply_start: failed to set active respond user_id=%s respond_id=%s", cb.from_user.id, respond_id)

    try:
        await _cleanup_resurrection_pings(cb.bot, int(respond_id), int(cb.from_user.id))
    except Exception:
        logger.exception("author_reply_start: resurrection cleanup failed respond_id=%s user_id=%s", respond_id, cb.from_user.id)

    await state.clear()
    await state.set_state(RespondFSM.author_reply_text)
    await state.update_data(respond_id=respond_id)

    try:
        m = await cb.bot.send_message(
            int(cb.from_user.id),
            prompt_text,
            parse_mode=ParseMode.HTML,
            link_preview_options=LinkPreviewOptions(is_disabled=True),
        )
        await state.update_data(prompt_message_id=int(m.message_id))
    except Exception:
        logger.exception("author_reply_start: failed to send prompt respond_id=%s user_id=%s", respond_id, cb.from_user.id)


@router.message(RespondFSM.author_reply_text)
async def author_reply_text(message: Message, state: FSMContext, redis: Any = None):
    text = (message.text or "").strip()
    if not text:
        return

    data = await state.get_data()
    respond_id = int(data.get("respond_id") or 0)
    if not respond_id:
        logger.warning("author_reply_text: missing respond_id in FSM user_id=%s", getattr(message.from_user, "id", None))
        await state.clear()
        return

    try:
        await _cleanup_resurrection_pings(message.bot, int(respond_id), int(message.from_user.id))
    except Exception:
        logger.exception("author_reply_text: resurrection cleanup failed respond_id=%s user_id=%s", respond_id, getattr(message.from_user, "id", None))

    with contextlib.suppress(Exception):
        pmid = data.get("prompt_message_id")
        if pmid:
            await message.bot.delete_message(chat_id=int(message.chat.id), message_id=int(pmid))
    with contextlib.suppress(Exception):
        await message.delete()

    async with get_sessionmaker()() as session:
        rrepo = RespondRepo(session)
        r = await rrepo.get_by_id(respond_id)
        if not r:
            logger.warning("author_reply_text: respond not found respond_id=%s", respond_id)
            await state.clear()
            return
        if int(r.author_user_id) != int(message.from_user.id):
            logger.warning("author_reply_text: access denied respond_id=%s user_id=%s", respond_id, getattr(message.from_user, "id", None))
            await state.clear()
            return

        forbidden = _respond_action_forbidden_text(r, action_label="Отправка сообщения")
        if forbidden:
            logger.info("author_reply_text: respond not available respond_id=%s", respond_id)
            with contextlib.suppress(Exception):
                await message.bot.send_message(int(message.chat.id), "🔒 Отклик уже закрыт. Сообщение не отправлено.")
            await state.clear()
            return

        st = _norm_status(getattr(r, "status", None))
        if st not in (ST_INVITED, ST_IN_DIALOG):
            logger.info("author_reply_text: invalid status for reply respond_id=%s status=%s", respond_id, st)
            with contextlib.suppress(Exception):
                await message.bot.send_message(int(message.chat.id), "⏳ Переписка пока недоступна.")
            await state.clear()
            return

        await _append_message_and_update_cards(message.bot, respond_id=respond_id, by="author", text=text)

        await rrepo.add_event(
            respond_id=int(respond_id),
            actor_role="author",
            actor_user_id=int(message.from_user.id),
            event_type="author_message",
            payload={},
        )

    try:
        await _set_active_respond(redis, int(message.from_user.id), int(respond_id))
    except Exception:
        logger.exception("author_reply_text: failed to set active respond user_id=%s respond_id=%s", getattr(message.from_user, "id", None), respond_id)

    await state.clear()


