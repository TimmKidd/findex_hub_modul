def _candidate_profile_from_saved_profile(profile: CandidateProfile) -> dict[str, Any]:
    prof: dict[str, Any] = {
        "name": str(profile.full_name or "").strip(),
        "age": str(profile.age or "").strip(),
        "citizenship": str(profile.citizenship or "").strip(),
        "experience": str(profile.experience or "").strip(),
    }

    if profile.resume_link:
        prof["resume_link"] = str(profile.resume_link).strip()

    if profile.resume_file_id:
        prof["resume_file_id"] = str(profile.resume_file_id).strip()

    if profile.resume_file_name:
        prof["resume_file_name"] = str(profile.resume_file_name).strip()

    return prof


def _profile_has_resume(prof: dict | None) -> bool:
    if not isinstance(prof, dict):
        return False
    return bool(prof.get("resume_file_id") or prof.get("resume_link"))


def _render_profile_lines(prof: dict | None) -> list[str]:
    p = prof if isinstance(prof, dict) else {}
    lines = [
        f"👤 <b>Имя:</b> {_h(p.get('name') or '—')}",
        f"🎂 <b>Возраст:</b> {_h(p.get('age') or '—')}",
        f"🌍 <b>Гражданство:</b> {_h(p.get('citizenship') or '—')}",
        f"💼 <b>Опыт:</b> {_h(p.get('experience') or '—')}",
    ]
    if p.get("resume_link"):
        lines.append(f"📎 <b>Резюме:</b> {_h(p.get('resume_link'))}")
    elif p.get("resume_file_id"):
        fname = p.get("resume_file_name") or "файл"
        lines.append(f"📎 <b>Резюме:</b> {_h(fname)} (файл)")
    return lines


def _ad_intro_context_lines(ad: Ad) -> list[str]:
    payload = getattr(ad, "payload", None) or {}
    role = str(payload.get("role") or getattr(ad, "role", None) or "employer").strip().lower()

    title = str(payload.get("title") or "").strip()
    location = str(payload.get("location") or "").strip()
    salary = str(payload.get("salary") or "").strip()
    schedule = str(payload.get("schedule") or "").strip()

    lines: list[str] = []

    if title:
        prefix = "👤" if role == "seeker" else "🔥"
        lines.append(f"{prefix} {_h(title)}")
    if location:
        lines.append(f"📍 {_h(location)}")
    if salary:
        lines.append(f"💰 {_h(salary)}")
    if role == "seeker" and schedule:
        lines.append(f"🕒 {_h(schedule)}")

    return lines


