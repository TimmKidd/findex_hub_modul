@router.callback_query(F.data.startswith(f"{CB_MENU}:"))
async def respond_to_menu(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    try:
        ad_id = int((cb.data or "").split(":")[1])
    except Exception:
        ad_id = 0

    try:
        r = _get_redis(redis)
        await r.set(PENDING_KEY.format(user_id=int(cb.from_user.id)), str(int(ad_id)), ex=PENDING_RESPOND_TTL_MIN * 60)
    except Exception:
        logger.exception("respond_to_menu: failed to persist pending ad context user_id=%s ad_id=%s", cb.from_user.id, ad_id)

    try:
        await state.clear()
    except Exception:
        logger.exception("respond_to_menu: state.clear failed user_id=%s", cb.from_user.id)

    if cb.message:
        await _edit_or_send(
            cb=cb,
            chat_id=int(cb.from_user.id),
            text="Ок.\nКонтекст сохранён на 15 минут.\n\nОткрой меню бота и нажми «🔙 Вернуться к отклику».",
            reply_markup=None,
            parse_mode=None,
        )


@router.callback_query(F.data == CB_BACK)
async def respond_back(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    ad_id: int | None = None
    try:
        r = _get_redis(redis)
        v = await r.get(PENDING_KEY.format(user_id=int(cb.from_user.id)))
        if v:
            ad_id = int(v)
    except Exception:
        logger.exception("respond_back: failed to read pending context user_id=%s", cb.from_user.id)
        ad_id = None

    if not ad_id:
        return await safe_answer(cb, "⏳ Сессия устарела.\nНажми «📩 Откликнуться» на объявлении ещё раз.", alert=True)

    ad = await _guard_ad_for_respond(cb, int(ad_id))
    if not ad:
        return

    await state.clear()

    text = _respond_intro_text(ad)

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=intro_kb(int(ad_id)),
        parse_mode=ParseMode.HTML,
    )
     if 'user_id' in locals() else int(cb.from_user.id),
        await state.get_state(),
    )
    await state.update_data(ad_id=int(ad_id), clean_thread_hint_key="respond_intro_choice")
    await state.set_state(RespondFSM.form_intro_choice)
     if 'user_id' in locals() else int(cb.from_user.id),
        await state.get_state(),
    )


@router.callback_query(F.data.startswith(f"{CB_RESUME}:"))
async def resume_respond(cb: CallbackQuery, redis: Any = None):
    await safe_answer(cb)

    try:
        respond_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        repo = RespondRepo(session)

        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        uid = int(cb.from_user.id)

        if uid == int(getattr(r, "author_user_id", 0) or 0):
            view = "author"
            try:
                fn = getattr(repo, "mark_owner_viewed_if_null", None)
                if callable(fn):
                    await fn(int(respond_id))
                r = await session.get(Respond, int(respond_id)) or r
            except Exception:
                logger.exception("resume_respond: mark_owner_viewed_if_null failed respond_id=%s", respond_id)

            ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
            if not ad:
                return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

            ok = await _upsert_card_for_view(cb.bot, session, r, ad, view=view)
            if not ok:
                return await safe_answer(cb, "⚠️ Не удалось открыть отклик", alert=True)

            await session.commit()

        elif uid == int(getattr(r, "candidate_user_id", 0) or 0):
            ad_id = int(getattr(r, "ad_id", 0) or 0)
            if not ad_id:
                return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

            opened = await _open_existing_candidate_respond(
                bot=cb.bot,
                ad_id=ad_id,
                user_id=int(cb.from_user.id),
                state=None,
                redis=redis,
            )
            if not opened:
                return await safe_answer(cb, "⚠️ Не удалось открыть отклик", alert=True)

        else:
            return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)

    try:
        await _set_active_respond(redis, int(cb.from_user.id), int(respond_id))
    except Exception:
        logger.exception(
            "resume_respond: failed to set active respond user_id=%s respond_id=%s",
            cb.from_user.id,
            respond_id,
        )

    try:
        await _cleanup_resurrection_pings(cb.bot, int(respond_id), int(cb.from_user.id))
    except Exception:
        logger.exception(
            "resume_respond: resurrection cleanup failed respond_id=%s user_id=%s",
            respond_id,
            cb.from_user.id,
        )


@router.callback_query(F.data.startswith(f"{CB_OPEN_FROM_LIST}:"))
async def open_respond_from_list(cb: CallbackQuery):
    await safe_answer(cb)

    parts = (cb.data or "").split(":")
    if len(parts) != 5:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    try:
        respond_id = int(parts[1])
        side = parts[2].strip()
        bucket = parts[3].strip()
        page = int(parts[4])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    if side not in {"candidate", "author"} or bucket not in {"active", "closed"}:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    async with get_sessionmaker()() as session:
        repo = RespondRepo(session)

        r: Respond | None = await session.get(Respond, int(respond_id))
        if not r:
            return await safe_answer(cb, "❌ Отклик не найден", alert=True)

        uid = int(cb.from_user.id)
        if side == "author":
            if uid != int(getattr(r, "author_user_id", 0) or 0):
                return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)
            view = "author"
            try:
                fn = getattr(repo, "mark_owner_viewed_if_null", None)
                if callable(fn):
                    await fn(int(respond_id))
                r = await session.get(Respond, int(respond_id)) or r
            except Exception:
                logger.exception("open_respond_from_list: mark_owner_viewed_if_null failed respond_id=%s", respond_id)
        else:
            if uid != int(getattr(r, "candidate_user_id", 0) or 0):
                return await safe_answer(cb, "🚫 Недостаточно прав", alert=True)
            view = "candidate"

        ad: Ad | None = await session.get(Ad, int(getattr(r, "ad_id", 0) or 0))
        if not ad:
            return await safe_answer(cb, "❌ Объявление не найдено", alert=True)

        text = _text_for(ad, r, view=view)
        kb = _kb_for(
            r,
            view=view,
            browse_mode=True,
            side=side,
            bucket=bucket,
            page=page,
        )

    await _edit_or_send(
        cb=cb,
        chat_id=int(cb.from_user.id),
        text=text,
        reply_markup=kb,
        parse_mode=ParseMode.HTML,
    )



@router.callback_query(F.data.startswith(f"{CB_INTRO_CONTINUE}:"))
async def intro_continue(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    try:
        ad_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    logger.info(
        "INTRO_CONTINUE: user_id=%s ad_id=%s cb_data=%s",
        cb.from_user.id,
        ad_id,
        cb.data,
    )

    ad = await _guard_ad_for_respond(cb, ad_id)
    if not ad:
        return

    data = await state.get_data()

    # если есть draft → показываем выбор
    if _draft_belongs_to_ad(data, ad_id) and _has_unfinished_draft_payload(data):
        await _upsert_service_message(
            cb.bot,
            redis,
            int(cb.from_user.id),
            ad_id,
            _respond_draft_choice_text(),
            reply_markup=draft_choice_kb(),
        )
        return

    # если есть сохранённый профиль → предлагаем быстрый отклик
    try:
        async with get_sessionmaker()() as session:
            cp_repo = CandidateProfileRepo(session)
            saved_profile = await cp_repo.get_by_user_id(int(cb.from_user.id))

        if saved_profile:
            await state.clear()
            await reset_cleanup_bucket(state)
            await state.update_data(
                ad_id=int(ad_id),
                form_preview_message_id=None,
                editing_field=None,
                clean_thread_hint_key="respond_saved_choice",
            )
            await state.set_state(RespondFSM.form_saved_choice)

            await _upsert_service_message(
                cb.bot,
                redis,
                int(cb.from_user.id),
                int(ad_id),
                _fast_respond_offer_text(ad, saved_profile),
                reply_markup=fast_respond_offer_kb(int(ad_id)),
            )
            return
    except Exception:
        logger.exception("intro_continue: failed to load candidate profile user_id=%s ad_id=%s", cb.from_user.id, ad_id)

    # старт формы
    await state.clear()
    await reset_cleanup_bucket(state)

    await state.update_data(
        ad_id=int(ad_id),
        form_preview_message_id=None,
        editing_field=None,
    )

    step1_text = (
        "🧾 <b>Анкета кандидата</b>\n\n"
        "⚡ Отклик займёт меньше минуты\n\n"
        "1/4 Введи <b>Имя</b> (обязательно)."
    )

    await _upsert_service_message(
        cb.bot,
        redis,
        int(cb.from_user.id),
        int(ad_id),
        step1_text,
        reply_markup=None,
    )

    await state.set_state(RespondFSM.form_name)


@router.callback_query(F.data.startswith(f"{CB_RESPOND}:"))
async def respond_entry(cb: CallbackQuery, state: FSMContext, redis: Any = None):
    await safe_answer(cb)

    try:
        ad_id = int((cb.data or "").split(":")[1])
    except Exception:
        return await safe_answer(cb, "⚠️ Некорректные данные", alert=True)

    logger.info(
        "RESPOND_ENTRY: user_id=%s ad_id=%s cb_data=%s",
        cb.from_user.id,
        ad_id,
        cb.data,
    )

    # 🔥 ANTI-RACE LOCK
    if not await _acquire_click_lock(redis, int(cb.from_user.id), int(ad_id)):
        return await safe_answer(cb, "⏳ Подожди...", alert=False)

    ad = await _guard_ad_for_respond(cb, ad_id)
    if not ad:
        return

    # если уже есть отклик → показываем напоминание + кнопку открытия карточки
    async with get_sessionmaker()() as session:
        existing = await _find_existing_candidate_respond(
            session,
            int(ad_id),
            int(cb.from_user.id),
        )
        if existing:
            logger.info(
                "RESPOND_ENTRY_DUPLICATE: user_id=%s ad_id=%s respond_id=%s",
                cb.from_user.id,
                ad_id,
                getattr(existing, "id", None),
            )

            await _show_existing_candidate_respond_notice(
                bot=cb.bot,
                redis=redis,
                user_id=int(cb.from_user.id),
                ad=ad,
                respond=existing,
                state=state,
            )
            return

    await state.clear()
    await reset_cleanup_bucket(state)

    await state.update_data(
        ad_id=int(ad_id),
        form_preview_message_id=None,
        editing_field=None,
        clean_thread_hint_key="respond_intro_choice",
    )
    await state.set_state(RespondFSM.form_intro_choice)

    text = _respond_intro_text(ad)

    await _upsert_intro_message(
        cb.bot,
        redis,
        int(cb.from_user.id),
        int(ad_id),
        text,
        reply_markup=intro_kb(int(ad_id)),
    )


